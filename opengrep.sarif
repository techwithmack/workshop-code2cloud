18}}}],"message":{"text":"Possibility of prototype polluting function detected. By adding or modifying attributes of an object prototype, it is possible to create attributes that exist on every object, or replace critical attributes with malicious ones. This can be problematic if the software depends on existence or non-existence of certain attributes, or uses pre-defined attributes of object prototype (such as hasOwnProperty, toString or valueOf). Possible mitigations might be: freezing the object prototype, using an object without prototypes (via Object.create(null) ), blocking modifications of attributes that resolve to object prototype, using Map instead of object."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.prototype-pollution.prototype-pollution-loop"},{"fingerprints":{"matchBasedId/v1":"8553af74b9cdeab1e67efaa9cfd4c1569b826101bb7bf844764ec22f4f0395e9a1511586d6c08e06c63a7e0dd0654383cb057dcbc4f418262fc6380bef6bf349_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-loop.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":41,"snippet":{"text":"    obj = obj[thisProp];"},"startColumn":5,"startLine":41}}}],"message":{"text":"Possibility of prototype polluting function detected. By adding or modifying attributes of an object prototype, it is possible to create attributes that exist on every object, or replace critical attributes with malicious ones. This can be problematic if the software depends on existence or non-existence of certain attributes, or uses pre-defined attributes of object prototype (such as hasOwnProperty, toString or valueOf). Possible mitigations might be: freezing the object prototype, using an object without prototypes (via Object.create(null) ), blocking modifications of attributes that resolve to object prototype, using Map instead of object."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.prototype-pollution.prototype-pollution-loop"},{"fingerprints":{"matchBasedId/v1":"98ea32f39b55b5087797b347cf7e8620232d50da97a9feb0b96689ce451e99ac9df13aca507a3f72c749411695fec58976495820e2d8148b4e312e28a5d649d7_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-loop.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":38,"endLine":56,"snippet":{"text":"    obj = obj[key] || (obj[key] = {});"},"startColumn":5,"startLine":56}}}],"message":{"text":"Possibility of prototype polluting function detected. By adding or modifying attributes of an object prototype, it is possible to create attributes that exist on every object, or replace critical attributes with malicious ones. This can be problematic if the software depends on existence or non-existence of certain attributes, or uses pre-defined attributes of object prototype (such as hasOwnProperty, toString or valueOf). Possible mitigations might be: freezing the object prototype, using an object without prototypes (via Object.create(null) ), blocking modifications of attributes that resolve to object prototype, using Map instead of object."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.prototype-pollution.prototype-pollution-loop"},{"fingerprints":{"matchBasedId/v1":"246ca3be784cb7a1d475311ef09d64c7b6fe1ef6bdd80885c1d754e6044925e81e8ca8cf5cb07714274aa9346ce003e688607bf4114da27efd54ba24662dd030_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/spawn-shell-true.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":54,"endLine":4,"snippet":{"text":"const ls = spawn('ls', ['-lh', '/usr'], {shell:true});"},"startColumn":12,"startLine":4}}}],"message":{"text":"Found '$SPAWN' with '{shell: true}'. This is dangerous because this call will spawn the command using a shell process. Doing so propagates current shell settings and variables, which makes it much easier for a malicious actor to execute commands. Use '{shell: false}' instead."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.spawn-shell-true"},{"fingerprints":{"matchBasedId/v1":"15fffe2bfe799c7c65eea9015846487ab369517005ee5c3d502c52bd10bd400c82e7e347dbe82f026e0b4d6c028d19875a6ddbc7a316eb7b08f591ad98d3a331_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/spawn-shell-true.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":65,"endLine":7,"snippet":{"text":"const pid = spawnSync('ls', ['-lh', '/usr'], {shell: '/bin/sh'});"},"startColumn":13,"startLine":7}}}],"message":{"text":"Found '$SPAWN' with '{shell: '/bin/sh'}'. This is dangerous because this call will spawn the command using a shell process. Doing so propagates current shell settings and variables, which makes it much easier for a malicious actor to execute commands. Use '{shell: false}' instead."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.spawn-shell-true"},{"fingerprints":{"matchBasedId/v1":"7d1684f1f3635c26ee5567001d1ee5e95324d194e655c5500d3ab93d427165b5e6a409756865b495cc4e2282ee7ff2d895ae91e745e79c667a42f0788a3aa1ad_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-knex-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":6,"endLine":25,"snippet":{"text":"  await connection.raw(`\n    INSERT INTO  (id, character, cartoon, link)\n    VALUES(\n        '${req.query.id}', \n        '${req.body.character}',\n        '${req.query.cartoon}', \n        '${req.foo.link}'\n    )\n    `);"},"startColumn":24,"startLine":17}}}],"message":{"text":"Detected SQL statement that is tainted by `req` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `knex.raw('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.knex-sqli"},{"fingerprints":{"matchBasedId/v1":"7bd3eb8d2d0e1ab7a603f35be0f2a6a743e0944316c4e474e04c6ec7851b515a5e3450df50c0007f278e5401edbba9cf8ab484d58b68d2b89df9bf58d704007d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-knex-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":6,"endLine":25,"snippet":{"text":"  await connection.raw(`\n    INSERT INTO  (id, character, cartoon, link)\n    VALUES(\n        '${req.query.id}', \n        '${req.body.character}',\n        '${req.query.cartoon}', \n        '${req.foo.link}'\n    )\n    `);"},"startColumn":24,"startLine":17}}}],"message":{"text":"Detected SQL statement that is tainted by `req` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, it is recommended to use parameterized queries or prepared statements. An example of parameterized queries like so: `knex.raw('SELECT $1 from table', [userinput])` can help prevent SQLi."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.sqli.node-knex-sqli"},{"fingerprints":{"matchBasedId/v1":"a8598fdeaaff8852fd35a0ec3679bfedff4400402be7dad51e8505c302c9feebb24ab6e6229628d64f7dee9a674a3d4b92e665f1471887d88eea220d6a60bdbb_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-mssql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":30,"snippet":{"text":"  const app = express();"},"startColumn":9,"startLine":30}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"05bee0c3fe3a0c2e98b845636c2075b6ad5e37b2af4de1a5dfc1fae5486c266521eef655b811498f5f7f81ee05177f4aa8ae0d8b810c51fe46f6b526d53fc6a2_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-mssql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":104,"endLine":43,"snippet":{"text":"      const dbResult = await request.query(`SELECT * FROM [foobar].[dbo].[users] WHERE user_id = ${id}`);"},"startColumn":44,"startLine":43}}}],"message":{"text":"Detected string concatenation with a non-literal variable in a `mssql` JS SQL statement. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `request.input('USER_ID', mssql.Int, id);`"},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.sqli.node-mssql-sqli"},{"fingerprints":{"matchBasedId/v1":"f2b1b2d340d353b07fdacdb42a757b9e1e1d5c5d5de770e804e9c9bc7476cd31977f2b7d5d76e33ef561dc3a04af7d619918261d37dbff556d109bcffc4ad9ac_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-mssql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":102,"endLine":43,"snippet":{"text":"      const dbResult = await request.query(`SELECT * FROM [foobar].[dbo].[users] WHERE user_id = ${id}`);"},"startColumn":100,"startLine":43}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"a8ef878e851b4840d3b4701e36cc470c937890f9c94328e8285c81d09104ea593c64a53d6da7c7a29581de167d3d273c84929ba8c6aaadd4514379a4426e791b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-mssql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":106,"endLine":66,"snippet":{"text":"  const dbResult = await request.query(\"SELECT * FROM [foobar].[dbo].[users] WHERE user_id =\" + userInput);"},"startColumn":40,"startLine":66}}}],"message":{"text":"Detected string concatenation with a non-literal variable in a `mssql` JS SQL statement. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `request.input('USER_ID', mssql.Int, id);`"},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.sqli.node-mssql-sqli"},{"fingerprints":{"matchBasedId/v1":"9deb6325b38df51f696520487b543997f7701e9a7656b414d399ae039ae6810c68cacdd21b6728d98c764f503e4bef879a31f4fda9ac38e9d65bb6e460b65446_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/sqli/node-mysql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":62,"endLine":7,"snippet":{"text":"    var createStmt = 'create temporary table ' + req.body.foo + '_jointemp (temp_seq int, '+ a + ' varchar(100)); ';"},"startColumn":50,"startLine":7}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."}