ine":10,"snippet":{"text":"    express.csrf()\n    express.methodOverride()"},"startColumn":5,"startLine":9}}}],"message":{"text":"Detected use of express.csrf() middleware before express.methodOverride(). This can allow GET requests (which are not checked by csrf) to turn into POST requests later."},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-no-csrf-before-method-override"},{"fingerprints":{"matchBasedId/v1":"80b6fecde131a2f3d9156bf44ed514908af088372a7c37eb3188877f98dcc703c6b5166b5276a69c075d78e2ef15c6c7cca1f3edc4488ea4f52e7d0c01e38e88_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/detect-pseudoRandomBytes.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":25,"endLine":5,"snippet":{"text":"crypto.pseudoRandomBytes"},"startColumn":1,"startLine":5}}}],"message":{"text":"Detected usage of crypto.pseudoRandomBytes, which does not produce secure random numbers."},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-pseudoRandomBytes"},{"fingerprints":{"matchBasedId/v1":"79e79803e74f1c978ccbcca2f94e43c71750e156983c360efbd9fc0f45baa82a5284c372db816060222fc5d2c935db55961265c7942675417ce74081199e019c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/html-in-template-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":10,"snippet":{"text":"let b = `<h1>hello ${planet}</h1>`;"},"startColumn":9,"startLine":10}}}],"message":{"text":"This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."},"properties":{},"ruleId":"opengrep-rules.lang.security.html-in-template-string"},{"fingerprints":{"matchBasedId/v1":"79e79803e74f1c978ccbcca2f94e43c71750e156983c360efbd9fc0f45baa82a5284c372db816060222fc5d2c935db55961265c7942675417ce74081199e019c_1"},"locations":[{"physicalLocatio