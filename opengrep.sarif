dLine":40,"snippet":{"text":"    await client.query(query)"},"startColumn":24,"startLine":40}}}],"message":{"text":"Detected SQL statement that is tainted by `event` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `connection.query('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.pg-sqli"},{"fingerprints":{"matchBasedId/v1":"0e25bbcdc5f8cfc222b80dc423ef6e985d8fc25d7942b70559d92fbc83f71db31709494b1c37398f7bb8e46d712dd019c439b281039b3c39c9aeb14789424e53_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/pg-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":29,"endLine":40,"snippet":{"text":"    await client.query(query)"},"startColumn":24,"startLine":40}}}],"message":{"text":"Detected string concatenation with a non-literal variable in a node-postgres JS SQL statement. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `client.query('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.sqli.node-postgres-sqli"},{"fingerprints":{"matchBasedId/v1":"364bd11e93b71904fa2d802e176259412067244c12ce956aae79ce412ed778478f53669b93dab189d874b301cd8141cab1f4bc55de06a7811f40c848297463e2_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/sequelize-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":124,"endLine":19,"snippet":{"text":"  const query = `INSERT INTO public.messages (body, encoded_message) VALUES ('${JSON.stringify(event)}', '${records[0]}');`;"},"startColumn":17,"startLine":19}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"0842622d3d6e58e9a4aae7bbbff6ffd5241318174f1811bf4a729cdc073d503d3fbdb76b0d6fb1d6341d1b4cf2cd1a104a17ec0e23a3ec6f0067bd551290acab_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/sequelize-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":32,"endLine":24,"snippet":{"text":"    await sequelize.query(query)"},"startColumn":27,"startLine":24}}}],"message":{"text":"Detected SQL statement that is tainted by `event` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `sequelize.query('SELECT * FROM projects WHERE status = ?', { replacements: ['active'], type: QueryTypes.SELECT });`"},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.sequelize-sqli"},{"fingerprints":{"matchBasedId/v1":"f7e7f5746635e919173eb9fbcd20e37b912dd24ec20b880ce6dc78a8d779dc4bdafd8c4d52770dadc6bafcd5f4af781107e2891b46dd0e9acf75993971631f1f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-eval.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":6,"snippet":{"text":"    eval(event['smth'])"},"startColumn":5,"startLine":6}}}],"message":{"text":"Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.browser.security.eval-detected"},{"fingerprints":{"matchBasedId/v1":"d79ca60eb30c3d9f4aed92e54bc1e304806eb418b51f707b835714cb31942053fcd7e574a31522fdc528c1718a8d7f1a82432f97b8ed98886f95b84a8d27289f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-eval.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":23,"endLine":6,"snippet":{"text":"    eval(event['smth'])"},"startColumn":10,"startLine":6}}}],"message":{"text":"The `eval()` function evaluates JavaScript code represented as a string. Executing JavaScript from a string is an enormous security risk. It is far too easy for a bad actor to run arbitrary code when you use `eval()`. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-eval"},{"fingerprints":{"matchBasedId/v1":"5c8aeb21488f49264b47a468b9a38b0e67e5b6d9cea3d60a695a7ed00e814dac1ab2aa66f2e4172044e9cd4c9e18d7afabdee0c3f0131a60c76004b7f728d0a8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-eval.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":66,"endLine":9,"snippet":{"text":"    var x = new Function('a', 'b', `return ${event['func']}(a,b)`)"},"startColumn":36,"startLine":9}}}],"message":{"text":"The `eval()` function evaluates JavaScript code represented as a string. Executing JavaScript from a string is an enormous security risk. It is far too easy for a bad actor to run arbitrary code when you use `eval()`. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-eval"},{"fingerprints":{"matchBasedId/v1":"009b96ce7d32664829a371ca32ed2e1b645a290bd050176566ce32140daa1c651cb9273a8d882e2fc297341682d923003028e61760632b0ec1d34e96a786609c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-eval.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":45,"endLine":12,"snippet":{"text":"    var y = Function('a', 'b', event['code'])"},"startColumn":32,"startLine":12}}}],"message":{"text":"The `eval()` function evaluates JavaScript code represented as a string. Executing JavaScript from a string is an enormous security risk. It is far too easy for a bad actor to run arbitrary code when you use `eval()`. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-eval"},{"fingerprints":{"matchBasedId/v1":"afc7bb29ad49096904cd8e4a20e6fb540dbca3b3b54f7f98eb8d65f986644ca79683ed6ce62b2c52e61f67029287dde37880aab6462f2aace084f20ae03bea2b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-response.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":2,"snippet":{"text":"    const html = `<div>${event.name}</div>`;"},"startColumn":18,"startLine":2}}}],"message":{"text":"Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates which will safely render HTML instead."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-html-string"},{"fingerprints":{"matchBasedId/v1":"00456910f8559c01cec2d3c27ace7c1e38fae6c0c6094a17b401141f5526a742198c56da94befd1a03c6bc4e222218f0b9e51ea883710ec0c79375a651d7586a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-response.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":2,"snippet":{"text":"    const html = `<div>${event.name}</div>`;"},"startColumn":18,"startLine":2}}}],"message":{"text":"This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."},"properties":{},"ruleId":"opengrep-rules.lang.security.html-in-template-string"},{"fingerprints":{"matchBasedId/v1":"ce7d8b88c19cd9ae2d0605cac33cdfb91bb2a0d4cc0af2fb9ddb858c4a575216e16833cce22219d0bc62981015102ad36eccbb8104914e57cc5f480d0f233c25_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-response.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":19,"endLine":13,"snippet":{"text":"        body: html,"},"startColumn":15,"startLine":13}}}],"message":{"text":"Detected user input flowing into an HTML response. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-html-response"},{"fingerprints":{"matchBasedId/v1":"d1fc4b974442c443c107fa5a76c43f6e1626cf2464b355cf48f0399501c8eb84db20af459668c8c7ba72d519ec614ed5adb95b244f2151fa614350a451589c2b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":64,"endLine":5,"snippet":{"text":"  await sendThisHtmlSomewhere(`<h1>message: ${event.name}</h1>`)"},"startColumn":31,"startLine":5}}}],"message":{"text":"Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates which will safely render HTML instead."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-html-string"},{"fingerprints":{"matchBasedId/v1":"f1a19df930c52a00f5bb1f2717c3da3892fb3622828082ea2acf0ad117e80355d9038c89dc0be51ac3f6835f636d85807768391c4d4c2c9cb3b0a4825282246f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":64,"endLine":5,"snippet":{"text":"  await sendThisHtmlSomewhere(`<h1>message: ${event.name}</h1>`)"},"startColumn":31,"startLine":5}}}],"message":{"text":"This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."},"properties":{},"ruleId":"opengrep-rules.lang.security.html-in-template-string"},{"fingerprints":{"matchBasedId/v1":"554fd5696b97ede2223189d58f9a875d527363dccae726cd2c64dd6b0f8eb3feb4120bb182b2a339d0d030def1c1ca3426ee5fecc26365d61805417cbaa45e56_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":61,"endLine":8,"snippet":{"text":"  const htmlResult = \"<h1>\" + \"message: \" + event['message'] + \"</h1>\";"},"startColumn":22,"startLine":8}}}],"message":{"text":"Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates which will safely render HTML instead."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-html-string"},{"fingerprints":{"matchBasedId/v1":"28e91e3ebf0cb78a544ac42c179ac183408f9302003b4cc7dfe981c3ab77a43dcdec3f574316ee0b4916edca395fe50a561b07da11e556086fe8dc89908cde70_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":36,"endLine":12,"snippet":{"text":"  html = html.concat(event.message)"},"startColumn":10,"startLine":12}}}],"message":{"text":"Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates which will safely render HTML instead."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-html-string"},{"fingerprints":{"matchBasedId/v1":"f5fed1fbc9bbc78f30c9a5b1fe557cbc1beadacebb2e52c283b4000a332ddc3fe320912cb4c03b2ffdbba06823bdb0d6badacb93ab7b2595faf4cae22e1c0c27_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":59,"endLine":17,"snippet":{"text":"  foobar(format('<div>Message: %s</div>', event.body.name))"},"startColumn":10,"startLine":17}}}],"message":{"text":"Detected user input flowing into a manually constructed HTML string. You may be accidentally bypassing secure methods of rendering HTML by manually constructing HTML and this could create a cross-site scripting vulnerability, which could let attackers steal sensitive user data. To be sure this is safe, check that the HTML is rendered safely. Otherwise, use templates which will safely render HTML instead."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-html-string"},{"fingerprints":{"matchBasedId/v1":"58a32aec83aac9cfb57ddc951028fb472d78867c95f61fc4fca2b2fef08dae177c21a9aa7658b24c79b4c87663e74eb6f9e1977d86594ea5dd9f0b6d46217439_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":59,"endLine":17,"snippet":{"text":"  foobar(format('<div>Message: %s</div>', event.body.name))"},"startColumn":10,"startLine":17}}}],"message":{"text":"User data flows into the host portion of this manually-constructed HTML. This can introduce a Cross-Site-Scripting (XSS) vulnerability if this comes from user-provided input. Consider using a sanitization library such as DOMPurify to sanitize the HTML within."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.raw-html-format"},{"fingerprints":{"matchBasedId/v1":"f1a19df930c52a00f5bb1f2717c3da3892fb3622828082ea2acf0ad117e80355d9038c89dc0be51ac3f6835f636d85807768391c4d4c2c9cb3b0a4825282246f_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-html-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":50,"endLine":26,"snippet":{"text":"  console.error(`<h1>message: ${event.name}</h1>`)"},"startColumn":17,"startLine":26}}}],"message":{"text":"This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."},"properties":{},"ruleId":"opengrep-rules.lang.security.html-in-template-string"},{"fingerprints":{"matchBasedId/v1":"745227e07e4ddc113b82d458f8e41f29bddf8589dede81289e31efa05f6dbb42cfcb903f71749560b90fa033f141d51a29993f88667195af566fb6e3ea51b5ea_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":80,"endLine":11,"snippet":{"text":"  const query = `INSERT INTO messages (body) VALUES ('${prettyPrint(event)}');`;"},"startColumn":17,"startLine":11}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"c8c6a924cb6ed859b94e29dc6cfd9b918214fab84b28b8a3ca45b671968bb5c49419807c23d4fa26defab3c54577acf901d0a9c2c099de0d783f9bd5d78fe03f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":29,"endLine":14,"snippet":{"text":"    await client.query(query)"},"startColumn":24,"startLine":14}}}],"message":{"text":"Detected SQL statement that is tainted by `event` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `connection.query('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.pg-sqli"},{"fingerprints":{"matchBasedId/v1":"a434bd72487da3c8e36884089bab9c76a019960097a8ee585c19b4bee65f5e6c23ac3ac6bb6f38aee184fcfea37ea232c5e3a6496c38a23a576a4b09a800cdd6_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":29,"endLine":14,"snippet":{"text":"    await client.query(query)"},"startColumn":24,"startLine":14}}}],"message":{"text":"Detected string concatenation with a non-literal variable in a node-postgres JS SQL statement. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `client.query('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.sqli.node-postgres-sqli"},{"fingerprints":{"matchBasedId/v1":"88c9ef96ceb54cb88ff8eaadbe6f8bcd514a4ed1d15ff1f1092f68ef63d1b62459022f4218e26da2e1adb15f49b0cc1a237fc2d75176515c2ed367e23cec3044_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":84,"endLine":17,"snippet":{"text":"    await client.query(\"INSERT INTO messages (body) VALUES ('\" + prettyPrint(event) + \"');\")"},"startColumn":24,"startLine":17}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"c72cce7b30390bc86d369027cadb7d600b9f8c934354cbaa645d8a330bfbfc0d792de880923ecfc111f9d4c13e3b9c8185d32ac4a043f37b50be89abf0fe6735_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":92,"endLine":17,"snippet":{"text":"    await client.query(\"INSERT INTO messages (body) VALUES ('\" +