ay block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"c8c0dd1ed321803ffe2219b03606a9b6670a7775acaa77b547b675983bb7b4e6d529d44d49c464365198ca04b67011bad8a516a1c5cebb4cc758168075ea094f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/jose/security/jwt-none-alg.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":49,"endLine":4,"snippet":{"text":"const jose = require(\"jose\");\nconst { JWK, JWT } = jose;\nconst token = JWT.verify('token-here', JWK.None);"},"startColumn":1,"startLine":2}}}],"message":{"text":"Detected use of the 'none' algorithm in a JWT token. The 'none' algorithm assumes the integrity of the token has already been verified. This would allow a malicious actor to forge a JWT token that will automatically be verified. Do not explicitly use the 'none' algorithm. Instead, use an algorithm such as 'HS256'."},"properties":{},"ruleId":"opengrep-rules.jose.security.jwt-none-alg"},{"fingerprints":{"matchBasedId/v1":"cc47bce15eff7fc219cb6f808d0d2d53442e6c18a19fcca04e5960410a5c38f58eeff35a455c430ddcb73e167fe46a0bd86daef7362fdf3c1995ed6bf1feb6cd_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/jquery/security/audit/jquery-insecure-method.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":60,"endLine":4,"snippet":{"text":"    var content = '<div>' + window.location.hash + '</div>';"},"startColumn":19,"startLine":4}}}],"message":{"text":"User controlled data in a HTML string may result in XSS"},"properties":{},"ruleId":"opengrep-rules.browser.security.raw-html-concat"},{"fingerprints":{"matchBasedId/v1":"5757c01187c67eb3bdb420944732befc6e4d585e977635e50217fe12779852d9bebb0494eed79cb642d6752c0ce8d83eab5dcae022c43ae1e554fe02d165e2cc_0"},"locations":[{"physicalLocation":{"