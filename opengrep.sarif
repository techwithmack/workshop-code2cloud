on":{"endColumn":42,"endLine":10,"snippet":{"text":"let hardcodedSecret = 'shhhhhhared-secret'"},"startColumn":24,"startLine":10}}}],"message":{"text":"A hard-coded credential was detected. It is not recommended to store credentials in source-code, as this risks secrets being leaked and used by either an internal or external malicious adversary. It is recommended to use environment variables to securely provide credentials or retrieve credentials from a secure vault or HSM (Hardware Security Module)."},"properties":{},"ruleId":"opengrep-rules.express.security.express-jwt-hardcoded-secret"},{"fingerprints":{"matchBasedId/v1":"3fee1838ebc4e66a4f135d8386f25e4f9c5fabe3f4b8757f0b9fb3a7f927adbf625257cdd6a66655f597bb500425c78d74980e959bf7b0c5b652a36b3fbd8d2d_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-jwt-hardcoded-secret.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":56,"endLine":12,"snippet":{"text":"app.get('/protected2', jwt({ secret: hardcodedSecret }), function(req, res) {"},"startColumn":24,"startLine":12}}}],"message":{"text":"No token revoking configured for `express-jwt`. A leaked token could still be used and unable to be revoked. Consider using function as the `isRevoked` option."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-jwt-not-revoked"},{"fingerprints":{"matchBasedId/v1":"3fee1838ebc4e66a4f135d8386f25e4f9c5fabe3f4b8757f0b9fb3a7f927adbf625257cdd6a66655f597bb500425c78d74980e959bf7b0c5b652a36b3fbd8d2d_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-jwt-hardcoded-secret.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":33,"endLine":22,"snippet":{"text":"app.get('/protected3', jwt(opts), function(req, res) {"},"startColumn":24,"startLine":22}}}],"message":{"text":"No token revoking configured for `express-jwt`. A leaked token could still be used and unable to be revoked. Consider using function as the `isRevoked` option."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-jwt-not-revoked"},{"fingerprints":{"matchBasedId/v1":"3fee1838ebc4e66a4f135d8386f25e4f9c5fabe3f4b8757f0b9fb3a7f927adbf625257cdd6a66655f597bb500425c78d74980e959bf7b0c5b652a36b3fbd8d2d_3"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-jwt-hardcoded-secret.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":61,"endLine":28,"snippet":{"text":"app.get('/ok-protected', jwt({ secret: process.env.SECRET }), function(req, res) {"},"startColumn":26,"startLine":28}}}],"message":{"text":"No token revoking configured for `express-jwt`. A leaked token could still be used and unable to be revoked. Consider using function as the `isRevoked` option."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-jwt-not-revoked"},{"fingerprints":{"matchBasedId/v1":"3fee1838ebc4e66a4f135d8386f25e4f9c5fabe3f4b8757f0b9fb3a7f927adbf625257cdd6a66655f597bb500425c78d74980e959bf7b0c5b652a36b3fbd8d2d_4"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-jwt-hardcoded-secret.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":38,"snippet":{"text":"app.get('/ok-protected', jwt(opts), function(req, res) {"},"startColumn":26,"startLine":38}}}],"message":{"text":"No token revoking configured for `express-jwt`. A leaked token could still be used and unable to be revoked. Consider using function as the `isRevoked` option."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-jwt-not-revoked"},{"fingerprints":{"matchBasedId/v1":"faddf8af9a9e99b28a8644a23d75bac37b32668ce80bf57f494745383b73718a72e8b63dee7929c8157c469bd0d8697b0ce736d267f86289200358b89597927e_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-phantom-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":2,"snippet":{"text":"const app = e