te-property-injection"},{"fingerprints":{"matchBasedId/v1":"5bd431fab8b2d5111e560d18889dad640cc4d1396d8b867c2292e63ddf80fb453fdbd32f3629d526696150729d61881608d62608d4b959a62c1e6f261c5cf513_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-assignment.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":43,"endLine":8,"snippet":{"text":"    items[req.query.name] = req.query.text;"},"startColumn":5,"startLine":8}}}],"message":{"text":"Bracket object notation with user input is present, this might allow an attacker to access all properties of the object and even it's prototype. Use literal values for object properties."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.remote-property-injection"},{"fingerprints":{"matchBasedId/v1":"88e12fa100adfc0fe2041a50c35611e67ddf5834355eed4995c73c6c2d0b2fc9754701112d09169b47309431d7ad2acf861e4dfe480d51a8c828e1ff75e40e99_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-assignment.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":43,"endLine":8,"snippet":{"text":"    items[req.query.name] = req.query.text;"},"startColumn":5,"startLine":8}}}],"message":{"text":"Possibility of prototype polluting assignment detected. By adding or modifying attributes of an object prototype, it is possible to create attributes that exist on every object, or replace critical attributes with malicious ones. This can be problematic if the software depends on existence or non-existence of certain attributes, or uses pre-defined attributes of object prototype (such as hasOwnProperty, toString or valueOf). Possible mitigations might be: freezing the object prototype, using an object without prototypes (via Object.create(null) ), blocking modifications of attributes that resolve to object prototype, using Map instead of object."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.prototype-pollution.prototype-pollution-assignment"},{"fingerprints":{"matchBasedId/v1":"117d98b14c172c301a5579c6f806de623d67b79b1697482f0c597aac10f3fa089445f06c14e2ca01342f6adf567651b0efc8e9225ef3eec08ccc6da36fd5f7cf_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-assignment.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":17,"snippet":{"text":"            items = req.session.todos[id] = {};"},"startColumn":21,"startLine":17}}}],"message":{"text":"Bracket object notation with user input is present, this might allow an attacker to access all properties of the object and even it's prototype. Use literal values for object properties."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.remote-property-injection"},{"fingerprints":{"matchBasedId/v1":"574df6ba35e7637ae893e9e402e792483a99f751ea663fac0a4dff0297262448b9e8bb777ddc3c132b73382dbf871f15d1273467e0839e305d6714a465dcaf86_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-assignment.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":20,"snippet":{"text":"        items[req.query.name] = req.query.text;"},"startColumn":9,"startLine":20}}}],"message":{"text":"Bracket object notation with user input is present, this might allow an attacker to access all properties of the object and even it's prototype. Use literal values for object properties."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.remote-property-injection"},{"fingerprints":{"matchBasedId/v1":"4dc635f0b0f7a94e54786069e6145add44ac3fcacf64ed9cdc07680ba2e4662d85fe5e247aa1b16805fe947cd9dcb19166fb9a35f55a5ed4a37815e63a1c05e6_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/prototype-pollution/prototype-pollution-assignment.js","uriBaseId":"%SRCROOT%"},"regi