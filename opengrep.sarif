quire('b')"},"startColumn":13,"startLine":34}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"dfea16d004a70d1e8cbcc25d1ef15fff510010831185a7515d26cea0125a4df090e8614271eab88cb65d7f8c16e12c6fb98dee49ad3eab9838e64b95bdf12833_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-require.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":37,"endLine":38,"snippet":{"text":"    var a = require(process.env.VAR)"},"startColumn":13,"startLine":38}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"ccbe3d77123b67a867d57ab42c1601eedcd117e62ec6e6aef3a3f13321a5a94e71263938a100a4e45cfc56873e9ac7323222fac8e1f79812dfd6bbe61ae08c5b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-redos.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":41,"endLine":2,"snippet":{"text":"const re = new RegExp(\"([a-z]+)+$\", \"i\");"},"startColumn":12,"startLine":2}}}],"message":{"text":"Detected the use of a regular expression `([a-z]+)+$` which appears to be vulnerable to a Regular expression Denial-of-Service (ReDoS). For this reason, it is recommended to review the regex and ensure it is not vulnerable to catastrophic backtracking, and if possible use a library which offers default safety against ReDoS vulnerabilities."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-redos"},{"fingerprints":{"matchBasedId/v1":"ccbe3d77123b67a867d57ab42c1601eedcd117e62ec6e6aef3a3f13321a5a94e71263938a100a4e45cfc56873e9ac7323222fac8e1f79812dfd6bbe61ae08c5b_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-redos.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":41,"endLine":4,"snippet":{"text":"const re = new RegExp(/([a-z]+)+$/, \"i\");"},"startColumn":12,"startLine":4}}}],"message":{"text":"Detected the use of a regular expression `([a-z]+)+$` which appears to be vulnerable to a Regular expression Denial-of-Service (ReDoS). For this reason, it is recommended to review the regex and ensure it is not vulnerable to catastrophic backtracking, and if possible use a library which offers default safety against ReDoS vulnerabilities."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-redos"},{"fingerprints":{"matchBasedId/v1":"05a932c6afdf753f89b637a75099a128c233cafa152238de0d8b8516ee6141064a919f494c472ccdac6da404acf8bf8e72553f092e151805b2b7f81d51b7e3e2_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-redos.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":19,"endLine":8,"snippet":{"text":"new RegExp(r, \"i\");"},"startColumn":1,"startLine":8}}}],"message":{"text":"Detected the use of a regular expression `^\\\\w+([-_+.]\\\\w+)*@\\\\w+([-.]\\\\w+)*\\\\.\\\\w+([-.]\\\\w+)*$` which appears to be vulnerable to a Regular expression Denial-of-Service (ReDoS). For this reason, it is recommended to review the regex and ensure it is not vulnerable to catastrophic backtracking, and if possible use a library which offers default safety against ReDoS vulnerabilities."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-redos"},{"fingerprints":{"matchBasedId/v1":"05a932c6afdf753f89b637a75099a128c233cafa152238de0d8b8516ee6141064a919f494c472ccdac6da404acf8bf8e72553f092e151805b2b7f81d51b7e3e2_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-redos.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":10,"endLine":10,"snippet":{"text":"r.test(a)"},"startColumn":1,"startLine":10}}}],"message":{"text":"Detected the use of a regular expression `^\\\\w+([-_+.]\\\\w+)*@\\\\w+([-.]\\\\w+)*\\\\.\\\\w+([-.]\\\\w+)*$` which appears to be vulnerable to a Regular expression Denial-of-Service (ReDoS). For this reason, it is recommended to review the regex and ensure it is not vulnerable to catastrophic backtracking, and if possible use a library which offers default safety against ReDoS vulnerabilities."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-redos"},{"fingerprints":{"matchBasedId/v1":"182d48f67d7e8f0b0ea087b0d1c8ecab60903b400a4abfb027e3891b597f1e3ea8bfe2275150da0d9648e776f2b0695dbb42f7a3faa89af195bce012d6a854d1_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-redos.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":13,"endLine":12,"snippet":{"text":"\"a\".match(r)"},"startColumn":1,"startLine":12}}}],"message":{"text":"Detected the use of a regular expression `^\\\\w+([-_+.]\\\\w+)*@\\\\w+([-.]\\\\w+)*\\\\.\\\\w+([-.]\\\\w+)*$` which appears to be vulnerable to a Regular expression Denial-of-Service (ReDoS). For this reason, it is recommended to review the regex and ensure it is not vulnerable to catastrophic backtracking, and if possible use a library which offers default safety against ReDoS vulnerabilities."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-redos"},{"fingerprints":{"matchBasedId/v1":"ae6414367aeddfd4a0a30b5a9c4badde018ac66610367e3bd6e1fd6ef356b48327555e20eec5560c098144e3ca7d29bc35f19908d4bc3ba40c3c129e1a6da439_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/hardcoded-hmac-key.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":79,"endLine":4,"snippet":{"text":"exports.hmac = data => crypto.createHmac('sha256', 'pa4qacea4VK9t9nGv7yZtwmj').update(data).digest('hex')"},"startColumn":24,"startLine":4}}}],"message":{"text":"Detected a hardcoded hmac key. Avoid hardcoding secrets and consider using an alternate option such as reading the secret from a config file or using an environment variable."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.hardcoded-hmac-key"},{"fingerprints":{"matchBasedId/v1":"ae6414367aeddfd4a0a30b5a9c4badde018ac66610367e3bd6e1fd6ef356b48327555e20eec5560c098144e3ca7d29bc35f19908d4bc3ba40c3c129e1a6da439_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/hardcoded-hmac-key.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":52,"endLine":10,"snippet":{"text":"  const hmac = crypto.createHmac('sha256', rsa_key)"},"startColumn":16,"startLine":10}}}],"message":{"text":"Detected a hardcoded hmac key. Avoid hardcoding secrets and consider using an alternate option such as reading the secret from a config file or using an environment variable."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.hardcoded-hmac-key"},{"fingerprints":{"matchBasedId/v1":"bfc740ec3f53914b14cb770e9a0fb5718b971d9828723a051152552b8ca55cb308a61553d06d23a0c54088cc85f71edf98a70c7a59b88af5946df916b86297e3_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/incomplete-sanitization.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":32,"endLine":3,"snippet":{"text":"    return s.replace(\"'\", \"''\");"},"startColumn":12,"startLine":3}}}],"message":{"text":"`s.replace` method will only replace the first occurrence when used with a string argument (\"'\"). If this method is used for escaping of dangerous data then there is a possibility for a bypass. Try to use sanitization library instead or use a Regex with a global flag."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.incomplete-sanitization"},{"fingerprints":{"matchBasedId/v1":"5d66f9a7dee3691783d1cc7697629a99c8d2591b70631bd2e7319dd34418869e534f3fa80f7fbd4a4b864fcb4cc85384bf9513ed3ae6a363b6b1efc0ff99005e_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/incomplete-sanitization.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":31,"endLine":8,"snippet":{"text":"    return s.replace('\\t', \"\");"},"startColumn":12,"startLine":8}}}],"message":{"text":"`s.replace` method will only replace the first occurrence when used with a string argument ('\\t'). If this method is used for escaping of dangerous data then there is a possibility for a bypass. Try to use sanitization library instead or use a Regex with a global flag."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.incomplete-sanitization"},{"fingerprints":{"matchBasedId/v1":"2f9ed02748e055858bbc130ebf103a68979d7932bf7b076054ab9358f5f0243941fc17c288ad2a3cfb77f12df9f7be8fa206aad918f5d55d69f5e37632089ff5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/incomplete-sanitization.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":14,"snippet":{"text":"  return html\n    .replace(\"<\", \"\")"},"startColumn":10,"startLine":13}}}],"message":{"text":"`html.replace` method will only replace the first occurrence when used with a string argument (\"<\"). If this method is used for escaping of dangerous data then there is a possibility for a bypass. Try to use sanitization library instead or use a Regex with a global flag."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.incomplete-sanitization"},{"fingerprints":{"matchBasedId/v1":"ccca005a8d90873173646ae062acb2b678c7ce86559ba0da4bc745d617cd7516fb284a185ce740036cb0c8794f5b4a69a559c1bb57eb9d57bfa05576eafb6616_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/incomplete-sanitization.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":15,"snippet":{"text":"  return html\n    .replace(\"<\", \"\")\n    .replace(\">\", \"\");"},"startColumn":10,"startLine":13}}}],"message":{"text":"`html\n    .replace(\"<\", \"\").replace` method will only replace the first occurrence when used with a string argument (\">\"). If this method is used for escaping of dangerous data then there is a possibility for a bypass. Try to use sanitization library instead or use a Regex with a global flag."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.incomplete-sanitization"},{"fingerprints":{"matchBasedId/v1":"535af54575f8fafa531133c2229d56991b758be5a506deb797dd82c394e8ce5ca346af88bd03387e9e149dcd04eb8356e5beb5549cc2c561e6444ac4aef0dc78_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/md5-used-as-password.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":6,"snippet":{"text":"    user.setPassword(digest);"},"startColumn":5,"startLine":6}}}],"message":{"text":"It looks like MD5 is used as a password hash. MD5 is not considered a secure password hash because it can be cracked by an attacker in a short amount of time. Use a suitable password hashing function such as bcrypt. You can use the `bcrypt` node.js package."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.md5-used-as-password"},{"fingerprints":{"matchBasedId/v1":"60a8cf8b5ae607247bb824ff22a0df17409ff63b39ff0eb2ba12b44abbcb8879010027a6b641d1f1ef0c74b0b461b9134a45a00ef6afdb946ca918a27102e9ec_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/path-traversal/path-join-resolve-traversal.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":58,"endLine":7,"snippet":{"text":"        var extr