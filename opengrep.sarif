h can lead to Server-Side Request Forgery (SSRF) vulnerabilities. It is recommended where possible to not allow user-input to craft the base request, but to be treated as part of the path or query parameter. When user-input is necessary to craft the request, it is recommeneded to follow OWASP best practices to prevent abuse. "},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-ssrf"},{"fingerprints":{"matchBasedId/v1":"fe6de7d59e983a583918c35297f6a339a25fd2771787c7b6d7b2862730d4e70715591a3c84f951c884eff20a5f99a13591f049139a43d64b41561a6426045162_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-ssrf.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":93,"snippet":{"text":"module.exports = function badWithTypes () {\n  return ({ body }: Request, res: Response, next: NextFunction) => {\n    const url = body.url\n    // ruleid: express-ssrf\n    request.get(url)\n  }\n\n}\n\nmodule.exports = function goodWithTypes () {\n  return ({ params, query, session }: Request, res: Response, next: NextFunction) => {\n    const url = session\n    // ok: express-ssrf\n     request.get(url)\n  }\n\n}"},"startColumn":1,"startLine":77}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"5e363fd86fc9f4100b376bc98dd6c90a29534178e5b1a25dab66b74bc752ccc135900d811f07a709c84701f5f80c55b53b8790f92c2ebb396e79572bbda2f29f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-ssrf.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":81,"snippet":{"text":"    request.get(url)"},"startColumn":17,"startLine":81}}}],"message":{"text":"The following request request.get() was found to be crafted from user-input `body` which can lead to Server-Side Request Forgery (SSRF) vulnerabilities. It is recommended where possible to not allow user-input to craft the base request, but to be treated as part of the path or query parameter. When user-input is necessary to craft the request, it is recommeneded to follow OWASP best practices to prevent abuse. "},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-ssrf"},{"fingerprints":{"matchBasedId/v1":"3ad55e6d6a51cfbac83e917d346f7f731b348704782b4c33c1400e11e11b48eb74a9b36d31cdb04e04b26995bfaf0da25bf4f56197b8ebccf33a3ead19bdf399_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-ssrf.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":111,"snippet":{"text":"module.exports = function goodWithTypes () {\n  return ({ params, query, session }: Request, res: Response, next: NextFunction) => {\n    const url = session\n    // ok: express-ssrf\n     request.get(url)\n  }\n\n}\n\n\nmodule.exports = function advanced () {\n  return ({ body }: Request, res: Response, next: NextFunction) => {\n    const url = body.url\n\n    joinModeOrDeepSemgrep(url, res, next)\n\n  }\n\n  function joinModeOrDeepSemgrep (url: string, res: Response, next: NextFunction) {\n\n      // todo: express-ssrf\n      request.get(url)\n\n  }\n\n}"},"startColumn":1,"startLine":86}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"5b66ccb0e961650a238e1034f91da04cf66d449c718de32095b819db14e422c22199e3bdd34a5e148a24994a75d2651e349faee0176793aea9f06f358b1b4113_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-third-party-object-deserialization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":70,"endLine":6,"snippet":{"text":"\tnode_serialize.unserialize(req.files.products.data.toString('utf8'))"},"startColumn":2,"startLine":6}}}],"message":{"text":"The following function call node_serialize.unserialize accepts user controlled data which can result in Remote Code Execution (RCE) through Object Deserialization. It is recommended to use secure data processing alternatives such as JSON.parse() and Buffer.from()."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-third-party-object-deserialization"},{"fingerprints":{"matchBasedId/v1":"29b29f2bf63ada71fd4dba3287cc5dc14859dd3b6e8b4b31849b792d4a19fd422227ccb5c562bd55d7c4cdaba210b5fc94cda169cc6cbc403c9bfdf98aef42e1_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-third-party-object-deserialization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":34,"endLine":15,"snippet":{"text":"\tserialize_to_js.deserialize(str)"},"startColumn":2,"startLine":15}}}],"message":{"text":"The following function call serialize_to_js.deserialize accepts user controlled data which can result in Remote Code Execution (RCE) through Object Deserialization. It is recommended to use secure data processing alternatives such as JSON.parse() and Buffer.from()."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-third-party-object-deserialization"},{"fingerprints":{"matchBasedId/v1":"cf22d98ca3325bf4b2ba3c4efd1d2884e0920f225be5b1fde11be4dafa410a64a71491f086311630e70a4f122a965e0d8eef132557bceead98715d0581a8c705_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":57,"snippet":{"text":"const expat = require('xml2json');\n\nfunction test1() {\n    var winston = require('winston'),\n        express = require('express');\n\n    var xmlParsingMiddleware = function(req, res, next) {\n        var buf = '';\n        req.setEncoding('utf8');\n        req.on('data', function (chunk) {\n            buf += chunk\n        });\n        // The rule isn't written in a way that it can find this\n        // todoruleid: express-xml2json-xxe-event\n        req.on('end', function () {\n            req.body = expat.toJson(buf, {coerce: true, object: true});\n            next();\n        });\n    };\n}\n\nfunction test2() {\n    const express = require('express')\n    const app = express()\n    const port = 3000\n\n    app.get('/', (req, res) => {\n        var buf = '';\n        req.setEncoding('utf8');\n        req.on('data', function (chunk) {\n            buf += chunk\n        });\n        // The rule isn't written in a way that it can find this\n        // todoruleid: express-xml2json-xxe-event\n        req.on('end', function () {\n            req.body = expat.toJson(buf, {coerce: true, object: true});\n            next();\n        });\n    })\n\n    app.listen(port, () => console.log(`Example app listening at http://localhost:${port}`))\n}\n\nfunction okTest() {\n    const express = require('express')\n    const app = express()\n    const port = 3000\n    const someEvent = require('some-event')\n\n    // ok: express-xml2json-xxe-event\n    someEvent.on('event', function (err, data) {\n        req.body = expat.toJson(data, {coerce: true, object: true});\n        next();\n    });\n\n    app.listen(port, () => console.log(`Example app listening at http://localhost:${port}`))\n}"},"startColumn":1,"startLine":1}}}],"message":{"text":"If unverified user data can reach the XML Parser it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.xml2json.security.audit.xml2json-xxe"},{"fingerprints":{"matchBasedId/v1":"fb8a31e95c093f607eca34e8892b531f7fc9c990cb898f004e694d8466f86e76910bc79005ebda12b8182084eca273ca1dd15f8884eb5e37ce994e7d6db1a489_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":37,"endLine":4,"snippet":{"text":"    var winston = require('winston'),"},"startColumn":19,"startLine":4}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"fb8a31e95c093f607eca34e8892b531f7fc9c990cb898f004e694d8466f86e76910bc79005ebda12b8182084eca273ca1dd15f8884eb5e37ce994e7d6db1a489_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":37,"endLine":5,"snippet":{"text":"        express = require('express');"},"startColumn":19,"startLine":5}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"32dbd5eb02291147a087e8e1137b2a6e6480d0f3c894501ffd6fb506b6a5ce08b03660dae4703949a6865db0d60e6fa431026b2c44d85f16a2f4c2f898a5a20e_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":39,"endLine":23,"snippet":{"text":"    const express = require('express')"},"startColumn":21,"startLine":23}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"25448841c74a3936173c83772f8d24e71f456c90405f424b63e4b7c9a568c18a27b26a400066a645a2459d78d1a67f5e89f7d0f94245c7f732a69c99d20b89a5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":24,"snippet":{"text":"    const app = express()"},"startColumn":11,"startLine":24}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"cb9be0740c9c5709e9a829a96b544007bdb0bb3251631b6b60d6cfef2c40ee100f506a6836d206611943930089408183743ae40d1740d64bfbf5501914346f72_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":39,"endLine":45,"snippet":{"text":"    const express = require('express')"},"startColumn":21,"startLine":45}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"25448841c74a3936173c83772f8d24e71f456c90405f424b63e4b7c9a568c18a27b26a400066a645a2459d78d1a67f5e89f7d0f94245c7f732a69c99d20b89a5_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":46,"snippet":{"text":"    const app = express()"},"startColumn":11,"startLine":46}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"cb9be0740c9c5709e9a829a96b544007bdb0bb3251631b6b60d6cfef2c40ee100f506a6836d206611943930089408183743ae40d1740d64bfbf5501914346f72_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-xml2json-xxe-event.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":48,"snippet":{"text":"    const someEvent = require('some-event')"},"startColumn":23,"startLine":48}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"cbb716d88d853e5df68d7a3538fdd3f827c3daf1c448ee4ab77e25f3d67138572ff7b1411e1ef6a3b7eb1205f0e50429c7fd0b3161e0f6253db3d6862ef5a6b4_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/possible-user-input-redirect.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":17,"snippet":{"text":"      res.redirect(toUrl)"},"startColumn":7,"startLine":17}}}],"message":{"text":"It looks like 'toUrl' is read from user input and it is used to as a redirect. Ensure 'toUrl' is not externally controlled, otherwise this is an open redirect."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.unknown-value-in-redirect"},{"fingerprints":{"matchBasedId/v1":"e1146c6499c0806315c8040f6cb9f0f49da91912a10f59b81da1f7614c3af70480b351174b8ae4ab11ecc62b6a97a2628a8f68e6f4f64d0428291cf369cd5c5c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/remote-property-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":3,"snippet":{"text":"var app = express();"},"startColumn":5,"startLine":3}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"93bfae9103b5200689c01fdc81aa1ced86d4aaa536fe0dae18c2fd03c3e1bedb6a676b2a15cf66cf870c5503c73b74421b5d02941e55989c0e749652449e51aa_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/remote-property-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":9,"snippet":{"text":"  myObj[prop] = function() {}"},"startColumn":3,"startLine":9}}}],"message":{"text":"Bracket object notation with user input is present, this might allow an attacker to access all properties of the object and even it's prototype. Use literal values for object properties."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.remote-property-injection"},{"fingerprints":{"matchBasedId/v1":"17f73d3033eea07f7331a882cae44d17e5e39f44be211878c3c419dd5a0109e807ea937f6abe140078169cf0bb0aa672b79bc942676c98b6e85e81824f526ad3_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/remote-property-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":29,"endLine":15,"snippet":{"text":"  myObj[req.body] = foobar()"},"startColumn":3,"startLine":15}}}],"message":{"text":"Bracket object notation with user input is present, this might allow an attacker to access all properties of the object and even it's prototype. Use literal values for object properties."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.remote-property-injection"},{"fingerprints":{"matchBasedId/v1":"cb8c25c475a2558c3bfd6032fdfd3b4009c7b8925be9b22115bc8b4d4af9b9c71242f129c53c77ed2ce7faff3202367c4726b194995f986a1c82abd8af4e8a6d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/res-render-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":2,"snippet":{"text":"const app = express()"},"startColumn":7,"startLine":2}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"09284d65fb01a549c067b06c7f05af4c081831c13116e9edcb8683331e61487d4fd953b0c3f828d4e1310d90b6be94207afcad40f45291e885a63ce2661db01e_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/res-render-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":46,"endLine":9,"snippet":{"text":"    return res.render(`tpl.${req.query.path}`, {foo: bar})"},"startColumn":23,"startLine":9}}}],"message":{"text":"User controllable data `req` enters `res.render(...)` this can lead to the loading of other HTML/templating pages that they may not be authorized to render. An attacker may attempt to use directory traversal techniques e.g. `../folder/index` to access other HTML pages on the file system. Where possible, do not allow users to define what should be  loaded in res.render or use an allow list for the existing application."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.res-render-injection"},{"fingerprints":{"matchBasedId/v1":"705ebfab702d6fd1a6fdfe31f3c2d0c6a8d0d0f499c285bbd9d2ffe2d253124667a5237f3fb884f1a32176035bd7f9030afd6def6b1599888f54e22a1ed2a551_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/res-render-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":61,"endLine":16,"snippet":{"text":"    return res.render('tpl.' + req.query.path + '.smth-else', {foo: bar})"},"startColumn":23,"startLine":16}}}],"message":{"text":"User controllable data `req` enters `res.render(...)` this can lead to the loading of other HTML/templating pages that they may not be authorized to render. An attacker may attempt to use directory traversal techniques e.g. `../folder/index` to access other HTML pages on the file system. Where possible, do not allow users to define what should be  loaded in res.render or use an allow list for the existing application."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.res-render-injection"},{"fingerprints":{"matchBasedId/v1":"f422a28c9f58b67471d3c4f2dc10e010a26c49334efcc5579413bdfac849e6bff1681e2412a2d2d828675f7f1dd65d2364641e34c484fbc183b1e0603c34fecf_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/direct-response-write.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":15,"snippet":{"text":"    res.send('<h1> Hello :' + name + \"</h1>\")"},"startColumn":14,"startLine":15}}}],"message":{"text":"User data flows into the host portion of this manually-constructed HTML. This can introduce a Cross-Site-Scripting (XSS) vulnerability if this comes from user-provided input. Consider using a sanitization library such as DOMPurify to sanitize the HTML within."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.raw-html-format"},{"fingerprints":{"matchBasedId/v1":"dbc5fbb5e508640cc353733ed6875448906fce426c6dd1648376a292bd065b68943d7d142eeb64b6b79af89767fdf509c5d3ecf31db5235d45dc17158ea4ddc8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/direct-response-write.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":45,"endLine":15,"snippet":{"text":"    res.send('<h1> Hello :' + name + \"</h1>\")"},"startColumn":14,"startLine":15}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"f422a28c9f58b67471d3c4f2dc10e010a26c49334efcc5579413bdfac849e6bff1681e2412a2d2d828675f7f1dd65d2364641e34c484fbc183b1e0603c34fecf_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/direct-response-write.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":37,"endLine":29,"snippet":{"text":"    res.send('<h1> Hello :' + xss(a) + \"</h1>\")"},"startColumn":14,"startLine":29}}}],"message":{"text":"User data flows into the host portion of this manually-constructed HTML. This can introduce a Cross-Site-Scripting (XSS) vulnerability if this comes from user-provided input. Consider using a sanitization library such as DOMPurify to sanitize the HTML within."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.raw-html-format"},{"fingerprints":{"matchBasedId/v