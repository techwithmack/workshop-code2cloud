sage":{"text":"The `vm` module enables compiling and running code within V8 Virtual Machine contexts. The `vm` module is not a security mechanism. Do not use it to run untrusted code. If code passed to `vm` functions is controlled by user input it could result in command injection. Do not let user input in `vm` functions."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.vm-runincontext-injection"},{"fingerprints":{"matchBasedId/v1":"7853205511c88ade5781d186c19dfd8efffcd5e1fabd5c14d24a411657a0f9177052fcc912b39c90cf76eb37a8c0247f2df3c34f0bda27afd0c56c4ca1ba0cb7_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/vm-runincontext-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":16,"snippet":{"text":"    vm.runInThisContext(code)"},"startColumn":5,"startLine":16}}}],"message":{"text":"The `vm` module enables compiling and running code within V8 Virtual Machine contexts. The `vm` module is not a security mechanism. Do not use it to run untrusted code. If code passed to `vm` functions is controlled by user input it could result in command injection. Do not let user input in `vm` functions."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.vm-runincontext-injection"},{"fingerprints":{"matchBasedId/v1":"98311a5fde2537bb0584b891eea35145cdacffa6700a0a9e83f013cebb8c875fea05b501148c65bdd74f408779f153f0e04c6beb281d9f60a6fd82f1e21d3a7c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/vm-runincontext-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":66,"endLine":22,"snippet":{"text":"    const fn1 = vm.compileFunction(code1, [], { parsingContext })"},"startColumn":17,"startLine":22}}}],"message":{"text":"The `vm` module enables compiling and running code within V8 Virtual Machine contexts. The `vm` module is not a security mechanism. Do not use it to run untrusted code. If code passed to `vm` functions is controlled by user input it could result in command injection. Do not let user input in `vm` functions."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.vm-runincontext-injection"},{"fingerprints":{"matchBasedId/v1":"0313052c1981576d1b4eaf2ed281755071ba73bcbf39087d82dadb35685e5e7a637b1316ca45b53fd6b5a28a18837d2858f18b9625d1dc07f3e8d8ae466a7930_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/vm-runincontext-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":75,"endLine":28,"snippet":{"text":"    const fn2 = vm.compileFunction(code2, [], { parsingContext: context })"},"startColumn":17,"startLine":28}}}],"message":{"text":"The `vm` module enables compiling and running code within V8 Virtual Machine contexts. The `vm` module is not a security mechanism. Do not use it to run untrusted code. If code passed to `vm` functions is controlled by user input it could result in command injection. Do not let user input in `vm` functions."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.vm-runincontext-injection"},{"fingerprints":{"matchBasedId/v1":"92d13705a5ffdb25554c612c666c88917945fe40bea434b25834f8a684b33d827577fc68182a05d789befab2ea8c28de0495ecc2b40ca451a10734cead16c24c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/vm-runincontext-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":7,"endLine":38,"snippet":{"text":"    const script = new vm.Script(`\n        function add(a, b) {\n          return a + ${event['something']};\n        }\n\n        const x = add(1, 2);\n    `);"},"startColumn":20,"startLine":32}}}],"message":{"text":"The `vm` module enables compiling and running code within V8 Virtual Machine contexts. The `vm` module is not a security mechanism. Do not use it to run untrusted code. If code passed to `vm` functions is controlled by user input it could result in command injection. Do not let user input in `vm` functions."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.vm-runincontext-injection"},{"fingerprints":{"matchBasedId/v1":"4503ffa315645efdae6c532fbed533477ab18d6beb61b06d311c323d0f94dfc18d3c8dfdac078f691372ecaf2bf7f0d6c105ab9bbb8a9a46e8e1a26e965d8f42_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/vm-runincontext-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":6,"endLine":77,"snippet":{"text":"    const script1 = new vm.Script(`\n        function add(a, b) {\n          return a + b;\n        }\n\n        const x = add(1, 2);\n    `);"},"startColumn":35,"startLine":71}}}],"message":{"text":"This looks like a JavaScript template string. Are you missing a '$' in front of '{...}'?"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.missing-template-string-indicator"},{"fingerprints":{"matchBasedId/v1":"8940ac1fb4614aa2b854a34375867b66f6a4a1c0c3f0c833527fb119ff72b808429443f4ab24dbcb1580e32b75a1032528cd08d645cfcdfe90a0b8a8137be5d8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/vm-runincontext-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":5,"endLine":77,"snippet":{"text":"    const script1 = new vm.Script(`\n        function add(a, b) {\n          return a + b;\n        }\n\n        const x = add(1, 2);\n    `);"},"startColumn":36,"startLine":71}}}],"message":{"text":"This looks like a JavaScript template string. Are you missing a '$' in front of '{...}'?"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.missing-template-string-indicator"},{"fingerprints":{"matchBasedId/v1":"048d3fa0cc24d0685ff86bb349228fa1e49e8e5cb3222362fe07a3e696d86a7d1246d1a38543c1d22bf51646817ea2058eeb637f86f1bc58485a7a1712453f90_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/bluebird/security/audit/tofastproperties-code-execution.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":5,"snippet":{"text":"  util.toFastProperties(input);"},"startColumn":25,"startLine":5}}}],"message":{"text":"Potential arbitrary code execution, whatever is provided to `toFastProperties` is sent straight to eval()"},"properties":{},"ruleId":"opengrep-rules.bluebird.security.audit.tofastproperties-code-execution"},{"fingerprints":{"matchBasedId/v1":"414b0b8e8ff5cb5e65bac7534cfd5e6539a8b042b0ddc31a87f635a63585d247a04109e2225270a4a2a5e090e048e200d66c7bc525040683b115b3e3b8f22c1b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/dom-based-xss.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":126,"endLine":2,"snippet":{"text":"document.write(\"<OPTION value=1>\"+document.location.href.substring(document.location.href.indexOf(\"default=\")+8)+\"</OPTION>\");"},"startColumn":1,"startLine":2}}}],"message":{"text":"Detected possible DOM-based XSS. This occurs because a portion of the URL is being used to construct an element added directly to the page. For example, a malicious actor could send someone a link like this: http://www.some.site/page.html?default=<script>alert(document.cookie)</script> which would add the script to the page. Consider allowlisting appropriate values or using an approach which does not involve the URL."},"properties":{},"ruleId":"opengrep-rules.browser.security.dom-based-xss"},{"fingerprints":{"matchBasedId/v1":"fd97412070b1c3542e568016b05c2214ef1f5a14b4109ab93a48a4ca460c3eb0cb2d85def47740048ede401adcee66c65927c56f05668684309f1c4249999425_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/dom-based-xss.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":126,"endLine":2,"snippet":{"text":"document.write(\"<OPTION value=1>\"+document.location.href.substring(document.location.href.indexOf(\"default=\")+8)+\"</OPTION>\");"},"startColumn":1,"startLine":2}}}],"message":{"text":"User controlled data in methods like `innerHTML`, `outerHTML` or `document.write` is an anti-pattern that can lead to XSS vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.browser.security.insecure-document-method"},{"fingerprints":{"matchBasedId/v1":"a55c6bea88178d244f2792514a35c050a9e081f7bea7afeeab2cfbe673cf7290392ef7bc02cfd1610a2bc5508dc840fb119c9ef79cb16b42435d2af4be059e31_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/dom-based-xss.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":125,"endLine":2,"snippet":{"text":"document.write(\"<OPTION value=1>\"+document.location.href.substring(document.location.href.indexOf(\"default=\")+8)+\"</OPTION>\");"},"startColumn":16,"startLine":2}}}],"message":{"text":"User controlled data in a HTML string may result in XSS"},"properties":{},"ruleId":"opengrep-rules.browser.security.raw-html-concat"},{"fingerprints":{"matchBasedId/v1":"08a6f46fcfa027b451ed2ed0deb5d525917db8b885431b6bbaeff9cf77b471cf30d5b635ec8a88904bf8083a1c92268589bf3ef2c195053b59653df8ae4f0dfe_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/eval-detected.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":42,"endLine":30,"snippet":{"text":"eval(dynamic + 'possibly malicious code');"},"startColumn":1,"startLine":30}}}],"message":{"text":"Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.browser.security.eval-detected"},{"fingerprints":{"matchBasedId/v1":"08a6f46fcfa027b451ed2ed0deb5d525917db8b885431b6bbaeff9cf77b471cf30d5b635ec8a88904bf8083a1c92268589bf3ef2c195053b59653df8ae4f0dfe_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/eval-detected.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":43,"endLine":33,"snippet":{"text":"eval(`${dynamic} possibly malicious code`);"},"startColumn":1,"startLine":33}}}],"message":{"text":"Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.browser.security.eval-detected"},{"fingerprints":{"matchBasedId/v1":"08a6f46fcfa027b451ed2ed0deb5d525917db8b885431b6bbaeff9cf77b471cf30d5b635ec8a88904bf8083a1c92268589bf3ef2c195053b59653df8ae4f0dfe_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/eval-detected.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":25,"endLine":36,"snippet":{"text":"eval(dynamic.concat(''));"},"startColumn":1,"startLine":36}}}],"message":{"text":"Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.browser.security.eval-detected"},{"fingerprints":{"matchBasedId/v1":"08a6f46fcfa027b451ed2ed0deb5d525917db8b885431b6bbaeff9cf77b471cf30d5b635ec8a88904bf8083a1c92268589bf3ef2c195053b59653df8ae4f0dfe_3"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/eval-detected.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":40,"snippet":{"text":"    eval(something);"},"startColumn":5,"startLine":40}}}],"message":{"text":"Detected the use of eval(). eval() can be dangerous if used to evaluate dynamic content. If this content can be input from outside the program, this may be a code injection vulnerability. Ensure evaluated content is not definable by external sources."},"properties":{},"ruleId":"opengrep-rules.browser.security.eval-detected"},{"fingerprints":{"matchBasedId/v1":"2590ef04f6b0c4464dd85043b620f886086f3371b7bf3a63419b5c4ace