mn":5,"startLine":10}}}],"message":{"text":"JQuery's `html` function is susceptible to Cross Site Scripting (XSS) attacks. If you're just passing text, consider `text` instead. Otherwise, use a function that escapes HTML such as edX's `HtmlUtils.setHtml()`."},"properties":{},"ruleId":"opengrep-rules.jquery.security.audit.prohibit-jquery-html"},{"fingerprints":{"matchBasedId/v1":"337d75ab8de0deb00fca5808f16f4ca4009a97f5591c4d7554343777531fef203142c3449cc0bb1ef742538c00406a19c4d7b6d78d88ffad02a44159c1a7e74b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/angular/security/detect-angular-element-methods.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":10,"snippet":{"text":"    angular.element('div').html($rootScope.foo)"},"startColumn":33,"startLine":10}}}],"message":{"text":"Use of angular.element can lead to XSS if user-input is treated as part of the HTML element within `html`. It is recommended to contextually output encode user-input, before inserting into `html`. If the HTML needs to be preserved it is recommended to sanitize the input using $sce.getTrustedHTML or $sanitize."},"properties":{},"ruleId":"opengrep-rules.angular.security.detect-angular-element-methods"},{"fingerprints":{"matchBasedId/v1":"69523dbfbcde07e9657e69913d800878718da4fb0e757feb27f96f0bd1e402c3d8a8c6edc969ebdd93350103ee77e7f3f3b211112f12c0d8901a9b0c2279235a_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/angular/security/detect-angular-element-methods.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":12,"snippet":{"text":"    angular.element('div').html($scope.foo)"},"startColumn":5,"startLine":12}}}],"message":{"text":"JQuery's `html` function is susceptible to Cross Site Scripting (XSS) attacks. If you're just passing text, consider `text` instead. Otherwise, use a function that escapes HTML such as edX's `HtmlUtils.setHtml()`."},"properties":{},"ruleId":"opengrep-rules.jquery.security.audit.prohibit