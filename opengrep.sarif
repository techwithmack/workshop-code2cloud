age.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":16,"snippet":{"text":"var app = express()"},"startColumn":5,"startLine":16}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"b41b0eb80670f94a8678107251bf79c147143f549e5e22497f837745208f51e510e83d5cc409bd78664b1449102b9d942989b1ed1d3b1ae8b5e9a8ffb55c74e4_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-check-directory-listing.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":3,"snippet":{"text":"var app = express();"},"startColumn":5,"startLine":3}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"ef29f2798c9fe7dc8594c88c608f222db2e385049b2894280749f1a3d12d8ff1884cc589981a1f4cee1b55e0c7d65d5e7d3662023474317ec05d74c2de892b15_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-check-directory-listing.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":7,"endLine":15,"snippet":{"text":"    serve(req, res, function onNext(err) {\n        if (err) return done(err)\n        index(req, res, done)\n    })"},"startColumn":5,"startLine":12}}}],"message":{"text":"Directory listing/indexing is enabled, which may lead to disclosure of sensitive directories and files. It is recommended to disable directory listing unless it is a public resource. If you need directory listing, ensure that sensitive files are inaccessible when querying the resource."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-directory-listing"},{"fingerprints":{"matchBasedId/v1":"3dc5d3d5b7cfceb4a58940c3a3805f64038e263a3afbfe48efe2d77e0f1c49ef6ddad414d52dd2f3d2322fc6f9e258b85170534b8300a9eb307f46b87a52268d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-check-directory-listing.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":21,"snippet":{"text":"app.use('/ftp', serveIndex('ftp', {\n    icons: true\n}));"},"startColumn":1,"startLine":19}}}],"message":{"text":"Directory listing/indexing is enabled, which may lead to disclosure of sensitive directories and files. It is recommended to disable directory listing unless it is a public resource. If you need directory listing, ensure that sensitive files are inaccessible when querying the resource."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-directory-listing"},{"fingerprints":{"matchBasedId/v1":"1a443edfd4e55fa8487b8ad286c5bfd0b48418c4220ea3d62f7d162298bfc5fc1d233d3538ce8dc8c4e46fb9eb6b1adaea72480e2eebfc6106e944c484bc1659_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-cookie-settings.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":3,"snippet":{"text":"var app = express()"},"startColumn":5,"startLine":3}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"62a85cccd714bca60893623324cf5739394a16a970bc4b7ccfa8d5e1ad2abb606a83cca62b0d741890e4ae20ddb357b28ccc6c547cb65b61184fec843c8f5e87_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-cookie-settings.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":18,"snippet":{"text":"  app.use(session(opts))"},"startColumn":11,"startLine":18}}}],"message":{"text":"Don’t use the default session cookie name Using the default session cookie name can open your app to attacks. The security issue posed is similar to X-Powered-By: a potential attacker can use it to fingerprint the server and target attacks accordingly."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-cookie-session-default-name"},{"fingerprints":{"matchBasedId/v1":"78052d30569bbc51c90b70dfec27b6fbe17dfc0e6d96e63d006965565e28ff582631c3efc7eac9296f0948e6957ed70a17b43d6e998a809045634de3b9a67c6a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-cookie-settings.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":6,"endLine":33,"snippet":{"text":"  app.use(session(Object.assign({\n    keys: ['key1', 'key2'],\n    name: 'foo'\n  }, {\n    cookie: {\n      httpOnly: true,\n      domain: 'example.com',\n      path: 'foo/bar',\n      expires: new Date(Date.now() + 60 * 60 * 1000)\n    }\n  })))"},"startColumn":11,"startLine":23}}}],"message":{"text":"Default session middleware settings: `secure` not set. It ensures the browser only sends the cookie over HTTPS."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-cookie-session-no-secure"},{"fingerprints":{"matchBasedId/v1":"24d021830d68cce262015d9c901e68e091a36b814320a23a8cb49825e766dd5381f8e16a3d353b6501cf747209f46ac53191d9c3de9f672a986a43d16b1d606c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-cookie-settings.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":5,"endLine":47,"snippet":{"text":"  app.use(session({\n    keys: ['key1', 'key2'],\n    name: 'foo',\n    cookie: {\n      secure: true,\n      domain: 'example.com',\n      path: 'foo/bar',\n      expires: new Date(Date.now() + 60 * 60 * 1000)\n    }\n  }))"},"startColumn":11,"startLine":38}}}],"message":{"text":"Default session middleware settings: `httpOnly` not set. It ensures the cookie is sent only over HTTP(S), not client JavaScript, helping to protect against cross-site scripting attacks."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-cookie-session-no-httponly"},{"fingerprints":{"matchBasedId/v1":"6bd2dd57ae2df7770288696493d36dce2189827e858fb2fbee4048ade412ed63f21bae32577eff719655a9ecdf114fd83a18487ba5cbdba25e4811590344bc1f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-cookie-settings.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":66,"snippet":{"text":"  app.use(session(opts))"},"startColumn":11,"startLine":66}}}],"message":{"text":"Default session middleware settings: `domain` not set. It indicates the domain of the cookie; use it to compare against the domain of the server in which the URL is being requested. If they match, then check the path attribute next."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-cookie-session-no-domain"},{"fingerprints":{"matchBasedId/v1":"2c17c08398b2202f3a2ce0e309e99186757df93b1abf910719ac2364077c148ac6de649ceecc0bac4e2318f6dd54c84e60b31b0457bb8eeb666820cb22cf9d8a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/express-cookie-settings.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":87,"snippet":{"text":"  app.use(session(opts))"},"startColumn":11,"startLine":87}}}],"message":{"text":"Default session middleware settings: `path` not set. It indicates the path of the cookie; use it to compare against the request path. If this and domain match, then send