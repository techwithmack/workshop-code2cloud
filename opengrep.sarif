d\") instead of mystring.replaceAll(\"bad\", \"good\") (https://discourse.threejs.org/t/replaceall-is-not-a-function/14585)"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.no-replaceall"},{"fingerprints":{"matchBasedId/v1":"c050d2f899013baf10c0392c189dded9130f159c1e478aed6830c20360f7855500c89fd38b37eb4402f5223b7e945ccbde4c23736717607cf66ddf95319f838f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/correctness/no-replaceall.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":7,"snippet":{"text":"const str2 = old_str2.replaceAll(\"\\t\", \"    \")"},"startColumn":14,"startLine":7}}}],"message":{"text":"The string method replaceAll is not supported in all versions of javascript, and is not supported by older browser versions. Consider using replace() with a regex as the first argument instead like mystring.replace(/bad/g, \"good\") instead of mystring.replaceAll(\"bad\", \"good\") (https://discourse.threejs.org/t/replaceall-is-not-a-function/14585)"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.no-replaceall"},{"fingerprints":{"matchBasedId/v1":"fadaa6f502c97e4c7c48c2dbd79d5c6400eb537bf6558027f722be5487fdd5bb1ea33fc2a13962a9bde63ab9e52598b328f862030283c986a7870f254801926c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/correctness/no-replaceall.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":9,"snippet":{"text":"const str3 = old_str3.replace(\"\\t\", \"    \");"},"startColumn":14,"startLine":9}}}],"message":{"text":"`old_str3.replace` method will only replace the first occurrence when used with a string argument (\"\\t\"). If this method is used for escaping of dangerous data then there is a possibility for a bypass. Try to use sanitization library instead or use a Regex with a global flag."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.incomplete-sanitization"},{"fingerprints":{"matchBasedId/v1":"b78570f9a796b77c2876a9ce77c9bf3