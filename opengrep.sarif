74f65e239f3903f644f4b42b4247b3bbe1c83154_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sandbox/security/audit/sandbox-code-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":21,"endLine":13,"snippet":{"text":"    s.run(code, cb);"},"startColumn":5,"startLine":13}}}],"message":{"text":"Make sure that unverified user data can not reach `sandbox`."},"properties":{},"ruleId":"opengrep-rules.sandbox.security.audit.sandbox-code-injection"},{"fingerprints":{"matchBasedId/v1":"9cc07b3e3703aaedb36e3be21a0d43a7fa08cb6601a1d1c96a5dc63f836fd8f0dd56fca415aa5a8643d766391850cf6d185e8992c6cf2b38ebe7eaa24ff8a095_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sandbox/security/audit/sandbox-code-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":36,"endLine":19,"snippet":{"text":"    s.run(`lol(${userInput})`, cb);"},"startColumn":5,"startLine":19}}}],"message":{"text":"Make sure that unverified user data can not reach `sandbox`."},"properties":{},"ruleId":"opengrep-rules.sandbox.security.audit.sandbox-code-injection"},{"fingerprints":{"matchBasedId/v1":"8471e8f8ca189584cc5ce8ce371f4103ccc1d3d8cb46dc859dd264eae9689377d68331d1d82ff376fef13d6d1991ea7260e26cbb4fee6428727e6e849264985c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sax/security/audit/sax-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":6,"endLine":13,"snippet":{"text":"    var sax = require(\"sax\"),\n    strict = false,\n    parser = sax.parser(strict);\n\n    parser.onattribute = function (attr) {\n        doSmth(attr)\n    };\n\n    parser.ondoctype = function(dt) {\n        processDocType(dt)\n    }"},"startColumn":5,"startLine":3}}}],"message":{"text":"Use of 'ondoctype' in 'sax' library detected. By default, 'sax' won't do anything with custom DTD entity definitions. If you're implementing a custom DTD entity definition, be sure not to introduce XML External Entity (XXE) vulnerabilities, or be absolutely sure that external entities received from a trusted source while processing XML."},"properties":{},"ruleId":"opengrep-rules.sax.security.audit.sax-xxe"},{"fingerprints":{"matchBasedId/v1":"330c828cc0d891c6847a4a7c8416b4252306a0f5b2d3ba26abb89e0e4b187191662a720c37a876c17b1458edf11e89bfcf9c00d7ec4cbf71010284a868ff8b77_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sax/security/audit/sax-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":29,"endLine":3,"snippet":{"text":"    var sax = require(\"sax\"),"},"startColumn":15,"startLine":3}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"21f4d8a1d7acdad71151e9cb60ea89d05fe265956e9190b67012ab1aa1575c8515c2450c85cd3c6f876cf0f07027ed3ad4040909c2b83a99acf7d167caa80b81_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sax/security/audit/sax-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":7,"endLine":33,"snippet":{"text":"    var saxStream = require(\"sax\").createStream(strict, options)\n\n    saxStream.on(\"opentag\", function (node) {\n        // same object as above\n    })\n\n    saxStream.on(\"doctype\", function (node) {\n        processType(node)\n    })"},"startColumn":5,"startLine":25}}}],"message":{"text":"Use of 'ondoctype' in 'sax' library detected. By default, 'sax' won't do anything with custom DTD entity definitions. If you're implementing a custom DTD entity definition, be sure not to introduce XML External Entity (XXE) vulnerabilities, or be absolutely sure that external entities received from a trusted source while processing XML."},"properties":{},"ruleId":"opengrep-rules.sax.security.audit.sax-xxe"},{"fingerprints":{"matchBasedId/v1":"6c36700e37476b23cacee81f2fffb7d18a74af8374f844ec252a39d9c3036a2ababa08ec3d125fffebeb16c46f39631c47aefe5987f278725218491041c18a59_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sax/security/audit/sax-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":25,"snippet":{"text":"    var saxStream = require(\"sax\").createStream(strict, options)"},"startColumn":21,"startLine":25}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"315e98c7b88cf996d44dfb23ac61703bfca600b276d0d91dc86df2fd01be6bdb8457c0f35858b9247803411ec27e7e5fc06c6601df9fbb2f85a5e1faf7411902_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sax/security/audit/sax-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":42,"snippet":{"text":"    var saxStream = require(\"sax\").createStream(strict, options)"},"startColumn":21,"startLine":42}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"59484bec50c4b406cfaef9f360dab4d2f924fe60184a0e25c719a900f22bd