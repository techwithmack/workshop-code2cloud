uery's `html` function is susceptible to Cross Site Scripting (XSS) attacks. If you're just passing text, consider `text` instead. Otherwise, use a function that escapes HTML such as edX's `HtmlUtils.setHtml()`."},"properties":{},"ruleId":"opengrep-rules.jquery.security.audit.prohibit-jquery-html"},{"fingerprints":{"matchBasedId/v1":"6a266a057b15455f8a214c01a666ed713bc26bb4ce2ca112b9bd88d3d3e5e772841456622eda142a5d014fcdee847bab4c488b016ac22667c9210167d3bfc849_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/jsonwebtoken/security/audit/example1.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":42,"endLine":15,"snippet":{"text":"        const { jti } = jwt.decode(token);"},"startColumn":25,"startLine":15}}}],"message":{"text":"Detected the decoding of a JWT token without a verify step. JWT tokens must be verified before use, otherwise the token's integrity is unknown. This means a malicious actor could forge a JWT token with any claims. Call '.verify()' before using the token."},"properties":{},"ruleId":"opengrep-rules.jsonwebtoken.security.audit.jwt-decode-without-verify"},{"fingerprints":{"matchBasedId/v1":"776e5dd95d3e1425b6aa774c355134014043c789546f5779cde99657f6b8f486ee3a9929814e1831ff60915c1577f2bb097670e7a872cbcb40fac57597104c36_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/jsonwebtoken/security/audit/jwt-decode-without-verify.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":5,"snippet":{"text":"  if (jwt.decode(token, true).param === true) {"},"startColumn":7,"startLine":5}}}],"message":{"text":"Detected the decoding of a JWT token without a verify step. JWT tokens must be verified before use, otherwise the token's integrity is unknown. This means a malicious actor could forge a JWT token with any claims. Call '.verify()' before using the token."},"properties":{},"ruleId":"opengrep-rules.jsonwebtoken.security.audit.jwt-decode-without-verify"},{"fingerprints":{"matchBasedId/v1":"7