` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-fs-filename"},{"fingerprints":{"matchBasedId/v1":"4aad7aefe0291a68fb3a58150dd26a1f43f25f3d91e86a6f31ac5fe81472f10b7dd5180036fca5f7ce282098bd4f1c37df12ad4dd537866c910988add3bc5e57_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-fs-filename.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":48,"endLine":14,"snippet":{"text":"  const data = await fs.promises.mkdir(fileName, {})"},"startColumn":40,"startLine":14}}}],"message":{"text":"Detected that function argument `fileName` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-fs-filename"},{"fingerprints":{"matchBasedId/v1":"4aad7aefe0291a68fb3a58150dd26a1f43f25f3d91e86a6f31ac5fe81472f10b7dd5180036fca5f7ce282098bd4f1c37df12ad4dd537866c910988add3bc5e57_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-fs-filename.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":21,"snippet":{"text":"  fs.writeFile(fileName, data, (err) => {"},"startColumn":16,"startLine":21}}}],"message":{"text":"Detected that function argument `fileName` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-fs-filename"},{"fingerprints":{"matchBasedId/v1":"6b0904249d3364740f1c8f5e7de4a5c494ee977144ca485c0ee73a9a51d652da65af3c4d95f9011112addd5bfa1d9b0c3a7e05f17a283a868b7dc065f66ae41c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-fs-filename.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":20,"endLine":6,"snippet":{"text":"  readFile(fileName)"},"startColumn":12,"startLine":6}}}],"message":{"text":"Detected that function argument `fileName` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-fs-filename"},{"fingerprints":{"matchBasedId/v1":"f45c48cd8cbc536763805dd91101acff42db69f46d8aa52f6dba4cfa83c462815147b191befa0880867b026e54edf2e21e9b178068fc1b38908205af47f5c248_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-fs-filename.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":48,"endLine":14,"snippet":{"text":"  const data = await fs.promises.mkdir(fileName, {})"},"startColumn":40,"startLine":14}}}],"message":{"text":"Detected that function argument `fileName` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-fs-filename"},{"fingerprints":{"matchBasedId/v1":"f45c48cd8cbc536763805dd91101acff42db69f46d8aa52f6dba4cfa83c462815147b191befa0880867b026e54edf2e21e9b178068fc1b38908205af47f5c248_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-fs-filename.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":21,"snippet":{"text":"  fs.writeFile(fileName, data, (err) => {"},"startColumn":16,"startLine":21}}}],"message":{"text":"Detected that function argument `fileName` has entered the fs module. An attacker could potentially control the location of this file, to include going backwards in the directory with '../'. To address this, ensure that user-controlled variables in file paths are validated."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-fs-filename"},{"fingerprints":{"matchBasedId/v1":"fa3ee83a35ff321afcd05d6ab90bf0bded72261d2d380683aff28d2138cb0bdda56284979181e4b3013b3b6932f67d00c4caf1caeabbc26d28a7902f81c825ae_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-regexp.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":40,"endLine":9,"snippet":{"text":"  const reg = new RegExp(\"\\\\w+\" + name)"},"startColumn":15,"startLine":9}}}],"message":{"text":"RegExp() called with a `name` function argument, this might allow an attacker to cause a Regular Expression Denial-of-Service (ReDoS) within your application as RegExP blocks the main thread. For this reason, it is recommended to use hardcoded regexes instead. If your regex is run on user-controlled input, consider performing input validation or use a regex checking/sanitization library such as https://www.npmjs.com/package/recheck to verify that the regex does not appear vulnerable to ReDoS."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-regexp"},{"fingerprints":{"matchBasedId/v1":"db6ab935616ba346b75ce471ecc06435a97ac57a3ba985c3cf90d40c38f238bfb371efe19af3cf475fd272d9a40ac752265d9371f2f76321f84fe76edce3ac3d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-require.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":33,"endLine":3,"snippet":{"text":"    var a = require(packageName)"},"startColumn":13,"startLine":3}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"9d2d5cdc99fbdc92aaaa34c7090cadbaa2c69c2bd58a77d462d39459e0bdcf059c70d6a35ca0993daa46732822c26d6f647c244670e9dc2b3a1a6d2e61e52bc4_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-require.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":33,"endLine":3,"snippet":{"text":"    var a = require(packageName)"},"startColumn":13,"startLine":3}}}],"message":{"text":"Detected the use of require(variable). Calling require with a non-literal argument might allow an attacker to load and run arbitrary code, or access arbitrary files."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-require"},{"fingerprints":{"matchBasedId/v1":"ff9c1469ef9792875c4ae10dbf803d719fedd17acb15103d342f432ff99aa90ce2cd4ef5109e0ca67914aa30064cd3aa335912879a352de91cd568007c729793_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-require.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":55,"endLine":9,"snippet":{"text":"    require(path.resolve(process.cwd(), file, source));"},"startColumn":5,"startLine":9}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"7435eeb6f0cde24de52c34da1ab3b51ad73485c5c51ad3fe33b697bfb30e3b77849ed6756886589aec43c3f64d2edf407bcafd89b2ec8cbeb764dababda71478_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-require.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":55,"endLine":9,"snippet":{"text":"    require(path.resolve(process.cwd(), file, source));"},"startColumn":5,"startLine":9}}}],"message":{"text":"Detected the use of require(variable). Calling require with a non-literal argument might allow an attacker to load and run arbitrary code, or access arbitrary files."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-require"},{"fingerprints":{"matchBasedId/v1":"540e23ae655d2f0fc1ac86da821f4e848249bed51bca9cf0f60e5de6cabb86fffac34697bcbe56dd5000dcd14ed210a84c787886bc31301c3509e42603008519_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/audit/detect-non-literal-require.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":17,"endLine":15,"snippet":{"text":"    require(lib).run(process.argv.slice(2));"},"startColumn":5,"startLine":15}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"e992daaafd69333e4cc41df85cbf636c6ac32149537ebdb93fc2cf5ad53aa7cf3b7416341a920fcefe6a47dea76e0e78059d56954b3e93de77f16654b105b4ca_0"},"locations":[{