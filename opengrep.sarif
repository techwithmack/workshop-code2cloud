time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"80d52716b5420f9e9ea3effd41503158f020ce0a4e48f449c065305ab99d34cb86d4dab2c838b83dbcd44f700cf26e0ac3768141980e79fc322f1e0548ac7ea1_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/grpc/security/grpc-nodejs-insecure-connection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":54,"endLine":23,"snippet":{"text":"    var {credentials, load, Client} = require('grpc');\n\n    var creds = someFunc() || credentials.createInsecure();\n\n    var client = new Client('127.0.0.1:50051', creds);"},"startColumn":5,"startLine":19}}}],"message":{"text":"Found an insecure gRPC connection. This creates a connection without encryption to a gRPC client/server. A malicious attacker could tamper with the gRPC message, which could compromise the machine."},"properties":{},"ruleId":"opengrep-rules.grpc.security.grpc-nodejs-insecure-connection"},{"fingerprints":{"matchBasedId/v1":"e6b8c3726f60b86268b42e5331e39a635e8b5decc8623a17a54afb2a6746970677ca2bb5040a95b034e3ba35d26189bba31e2ee44c53c0a5378c99e6d9e2e98a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/grpc/security/grpc-nodejs-insecure-connection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":54,"endLine":19,"snippet":{"text":"    var {credentials, load, Client} = require('grpc');"},"startColumn":39,"startLine":19}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"5d1c74c491127624d9e29f99184860085a19e095fba12c3db31b77459bcb762f37fce19f6b6f368d333a67730e660b662dab886ea72d859554776f0a1f0c58a9_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/grpc/security/grpc-nodejs-insecure-connection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":75,"endLine":43,"snippet":{"text":"    var grpc = require('grpc');\n\n    var booksProto = grpc.load('books.proto');\n\n    var server = new grpc.Server();\n\n    server.addProtoService(booksProto.books.BookService.service, {});\n\n    server.bind('0.0.0.0:50051', grpc.ServerCredentials.createInsecure());"},"startColumn":5,"startLine":35}}}],"message":{"text":"Found an insecure gRPC connection. This creates a connection without encryption to a gRPC client/server. A malicious attacker could tamper with the gRPC message, which could compromise the machine."},"properties":{},"ruleId":"opengrep-rules.grpc.security.grpc-nodejs-insecure-connection"},{"fingerprints":{"matchBasedId/v1":"fc70b14eab8ef0850a712a8d426acff28df49cce1fea3c2eed3f84a83d487168ffc5e33708680f3e3ace76b2abc93a91e9c37d9535ac34e0826c848d595ebb68_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/grpc/security/grpc-nodejs-insecure-connection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":31,"endLine":35,"snippet":{"text":"    var grpc = require('grpc');"},"startColumn":16,"startLine":35}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"3293740d26acfe5c828fea1371523229655a3553bb2270c5da73455cd5158108f65d049da39977e6