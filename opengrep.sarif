ext":"Detected the decoding of a JWT token without a verify step. JWT tokens must be verified before use, otherwise the token's integrity is unknown. This means a malicious actor could forge a JWT token with any claims. Set 'verify' to `true` before using the token."},"properties":{},"ruleId":"opengrep-rules.jwt-simple.security.jwt-simple-noverify"},{"fingerprints":{"matchBasedId/v1":"f7ba0740bbdfea8df5fa52a8d1e76bed328d25cb2ba25e67ad89a8dd9b784ef785fed08e6e8f667e11c871d8b4a49917b5569b5a412848bbd58a17b231cff7e6_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/jwt-simple/security/jwt-simple-noverify.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":55,"endLine":83,"snippet":{"text":"    const decoded = jwt.decode(token, secretKey, true);"},"startColumn":21,"startLine":83}}}],"message":{"text":"Detected the decoding of a JWT token without a verify step. JWT tokens must be verified before use, otherwise the token's integrity is unknown. This means a malicious actor could forge a JWT token with any claims. Set 'verify' to `true` before using the token."},"properties":{},"ruleId":"opengrep-rules.jwt-simple.security.jwt-simple-noverify"},{"fingerprints":{"matchBasedId/v1":"9dcfff5364c7accc52a1fe5b8a4872cfff88cad992b242ace62fa720ab948cdc31798ba63dcd809d7fbfb729071e6359d073c52080324fe34ca393e55f2330bc_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/jwt-simple/security/jwt-simple-noverify.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":58,"endLine":100,"snippet":{"text":"    const decoded = jwt.decode(token, secretKey, 'false');"},"startColumn":21,"startLine":100}}}],"message":{"text":"Detected the decoding of a JWT token without a verify step. JWT tokens must be verified before use, otherwise the token's integrity is unknown. This means a malicious actor could forge a JWT token with any claims. Set 'verify' to `true` before using the token."},"properties":{},"ruleId":"opengrep-rules.jwt-simple.security.jwt-simple-noverify"},{"fingerprints":{"matchBasedId/v1":"c39f432166ed7ee40cb8983ffb72599f3b5d990a7ecc59ca3391dda5eaf3219d9037b43ed82ba53094bd1cd54778b4ac90243dd1f15da4a185d7662735694d8a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/best-practice/assigned-undefined.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":17,"endLine":6,"snippet":{"text":"alert(undefined); //alerts \"undefined\""},"startColumn":1,"startLine":6}}}],"message":{"text":"found alert() call; should this be in production code?"},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.javascript-alert"},{"fingerprints":{"matchBasedId/v1":"6230ac17460e9a73e7a69fa9d71ed3b76f82ffbfe5772fd3fd0146d1e30799defc2cfc58f3343c909699440f91e8ddaf6745c259e46e74552ced3de59e8de86a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/best-practice/assigned-undefined.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":28,"endLine":8,"snippet":{"text":"var undefined = \"new value\";"},"startColumn":1,"startLine":8}}}],"message":{"text":"`undefined` is not a reserved keyword in Javascript, so this is \"valid\" Javascript but highly confusing and likely to result in bugs."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.assigned-undefined"},{"fingerprints":{"matchBasedId/v1":"c39f432166ed7ee40cb8983ffb72599f3b5d990a7ecc59ca3391dda5eaf3219d9037b43ed82ba53094bd1cd54778b4ac90243dd1f15da4a185d7662735694d8a_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/best-practice/assigned-undefined.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":17,"endLine":9,"snippet":{"text":"alert(undefined) // alerts \"new value\""},"startColumn":1,"startLine":9}}}],"message":{"text":"found alert() call; should this be in production code?"},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.javascript-alert"},{"fingerprints":{"matchBasedId/v1":"6230ac17460e9a73e7a69fa9d71ed3b76f82ffbfe5772fd3fd0146d1e30799defc2cfc58f3