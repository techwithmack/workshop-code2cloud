l handler getResponseWithPayload. This could be a server-side request forgery. A user could call a restricted API or leak internal headers to an unauthorized party. Validate your user arguments against an allowlist of known URLs, or consider refactoring so that user-controlled data is not necessary."},"properties":{},"ruleId":"opengrep-rules.apollo.security.apollo-axios-ssrf"},{"fingerprints":{"matchBasedId/v1":"d8af2525932063226349c30ab6345d2b45a3ba1904a59a9569ec92b21b6dd415be6b4cdd21c3cf695dc05fa9ac20e118a11ef79f08bed9a5cb01f0005a16d88c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/argon2/security/unsafe-argon2-config.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":38,"endLine":32,"snippet":{"text":"    .hash(user.Password, hashSettings)"},"startColumn":26,"startLine":32}}}],"message":{"text":"Prefer Argon2id where possible. Per RFC9016, section 4 IETF recommends selecting Argon2id unless you can guarantee an adversary has no direct access to the computing environment."},"properties":{},"ruleId":"opengrep-rules.argon2.security.unsafe-argon2-config"},{"fingerprints":{"matchBasedId/v1":"d8af2525932063226349c30ab6345d2b45a3ba1904a59a9569ec92b21b6dd415be6b4cdd21c3cf695dc05fa9ac20e118a11ef79f08bed9a5cb01f0005a16d88c_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/argon2/security/unsafe-argon2-config.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":38,"endLine":47,"snippet":{"text":"    .hash(user.Password, hashSettings)"},"startColumn":26,"startLine":47}}}],"message":{"text":"Prefer Argon2id where possible. Per RFC9016, section 4 IETF recommends selecting Argon2id unless you can guarantee an adversary has no direct access to the computing environment."},"properties":{},"ruleId":"opengrep-rules.argon2.security.unsafe-argon2-config"},{"fingerprints":{"matchBasedId/v1":"1f0a3dd9c9c13de7a6445292ab2d52242a77763dac90866f47103a0169913530d97b05b36edaca953c16a231c07e383a926db8fe77f3ed1b9ae05ad41ee5d649_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/audit/detect-replaceall-sanitization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":80,"endLine":4,"snippet":{"text":"    tableData[i].description = tableData[i].description.replaceAll('<', '&lt;').replaceAll('>', '&gt;')"},"startColumn":32,"startLine":4}}}],"message":{"text":"Detected a call to `replaceAll()` in an attempt to HTML escape the string `tableData[i].description`. Manually sanitizing input through a manually built list can be circumvented in many situations, and it's better to use a well known sanitization library such as `sanitize-html` or `DOMPurify`."},"properties":{},"ruleId":"opengrep-rules.audit.detect-replaceall-sanitization"},{"fingerprints":{"matchBasedId/v1":"8ba2416a1db57709420a4e2d9c4f2ce6659b4cc9404689fb6033e05b38aec3755350fb10336d01f5bde80faa83e55c22e04677ef07ad57ed384dafb445fb7afc_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/audit/detect-replaceall-sanitization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":80,"endLine":4,"snippet":{"text":"    tableData[i].description = tableData[i].description.replaceAll('<', '&lt;').replaceAll('>', '&gt;')"},"startColumn":32,"startLine":4}}}],"message":{"text":"The string method replaceAll is not supported in all versions of javascript, and is not supported by older browser versions. Consider using replace() with a regex as the first argument instead like mystring.replace(/bad/g, \"good\") instead of mystring.replaceAll(\"bad\", \"good\") (https://discourse.threejs.org/t/replaceall-is-not-a-function/14585)"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.no-replaceall"},{"fingerprints":{"matchBasedId/v1":"8b827ac449c8f249dd2b7f0256ce3924952951f516f407beb6ae634d6aa9651eca635b9d52492b15aa7b3ce5cdf11e68e6f8cd345423e83c90d5fea8143c79f5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/audit/detect-replaceall-sanitization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":104,"endLine":4,"snippet":{"text":"    tableData[i].description = tableData[i].description.replaceAll('<', '&lt;').replaceAll('>', '&gt;')"},"startColumn":32,"startLine":4}}}],"message":{"text":"Detected a call to `replaceAll()` in an attempt to HTML escape the string `tableData[i].description.replaceAll('<', '&lt;')`. Manually sanitizing input through a manually built list can be circumvented in many situations, and it's better to use a well known sanitization library such as `sanitize-html` or `DOMPurify`."},"properties":{},"ruleId":"opengrep-rules.audit.detect-replaceall-sanitization"},{"fingerprints":{"matchBasedId/v1":"8d6200b6251e7518b056784017f2781a414966efb2d0ee8d029e576e237915607fe41195a0300ef7e298bd7cecb863f09d88e4c27e043676fa16b59c20e9377b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/audit/detect-replaceall-sanitization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":104,"endLine":4,"snippet":{"text":"    tableData[i].description = tableData[i].description.replaceAll('<', '&lt;').replaceAll('>', '&gt;')"},"startColumn":32,"startLine":4}}}],"message":{"text":"The string method replaceAll is not supported in all versions of javascript, and is not supported by older browser versions. Consider using replace() with a regex as the first argument instead like mystring.replace(/bad/g, \"good\") instead of mystring.replaceAll(\"bad\", \"good\") (https://discourse.threejs.org/t/replaceall-is-not-a-function/14585)"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.no-replaceall"},{"fingerprints":{"matchBasedId/v1":"e1d93ff29d3fd5b38191a098c4ee316b1c46b708f5e3dac409897ac51a36c428e76db772be4dd758b7e81c8e3e88cf5a9b2be46ee01df25a1f8df8f3778642f9_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/audit/detect-replaceall-sanitization.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":94,"endLine":7,"snippet":{"text":"    tableData[i].description = tableData[i].description.replaceAll('<', 'left angle bracket')"},"startColumn":32,"startLine":7}}}],"message":{"text":"The string method replaceAll is not supported in all versions of javascript, and is not supported by older browser versions. Consider using replace() with a regex as the first argument instead like mystring.replace(/bad/g, \"good\") instead of mystring.replaceAll(\"bad\", \"good\") (https://discourse.threejs.org/t/replaceall-is-not-a-function/14585)"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.no-replaceall"},{"fingerprints":{"matchBasedId/v1":"9ca250267b5c1f95c5375661aaa1c2445042aeab59d2288b63c8d9025573d67dae5de44267c5e2e5bddf5caa1091a0c3a8a16230cd925e756d216cfdd097104b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/detect-child-process.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":5,"snippet":{"text":"    cp.exec(`cat *.js ${event['file']}| wc -l`, (error, stdout, stderr) => {"},"startColumn":13,"startLine":5}}}],"message":{"text":"Allowing spawning arbitrary programs or running shell processes with arbitrary arguments may end up in a command injection vulnerability. Try to avoid non-literal values for the command string. If it is not possible, then do not let running arbitrary commands, use a white list for inputs."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.detect-child-process"},{"fingerprints":{"matchBasedId/v1":"ce6b409430973868805ab5c9d3eb2dd06abd1486ad004f483004a433c990801d23ef83f2d3134e3fde357afa56db164499a7ddaf93efc5e5f9ebcecc25714a55_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/detect-child-process.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":5,"snippet":{"text":"    cp.exec(`cat *.js ${event['file']}| wc -l`, (error, stdout, stderr) => {"},"startColumn":13,"startLine":5}}}],"message":{"text":"Detected calls to child_process from a function argument `event`. This could lead to a command injection if the input is user controllable. Try to avoid calls to child_process, and if it is needed ensure user input is correctly sanitized or sandboxed. "},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-child-process"},{"fingerprints":{"matchBasedId/v1":"1ce905d637ae8ae78e52da02099806c1b99f1c8747c375e307759e7dab2e93501c78a9efc0b23217382244c07bc3c82bbbc5a0eb72f56c9e57819e1081973362_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/detect-child-process.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":10,"snippet":{"text":"    cp.spawnSync(event['cmd']);"},"startColumn":18,"startLine":10}}}],"message":{"text":"Allowing spawning arbitrary programs or running shell processes with arbitrary arguments may end up in a command injection vulnerability. Try to avoid non-literal values for the command string. If it is not possible, then do not let running arbitrary commands, use a white list for inputs."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.detect-child-process"},{"fingerprints":{"matchBasedId/v1":"f84e759e0d89134e13753b2f9356be6548bba2e0382b6bc5f77ff8197b9a1b86780ab5d287eac55b16595e69158fee4c079426de7cc4a82ec9f75a5366cd304f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/detect-child-process.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":10,"snippet":{"text":"    cp.spawnSync(event['cmd']);"},"startColumn":18,"startLine":10}}}],"message":{"text":"Detected calls to child_process from a function argument `event`. This could lead to a command injection if the input is user controllable. Try to avoid calls to child_process, and if it is needed ensure user input is correctly sanitized or sandboxed. "},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-child-process"},{"fingerprints":{"matchBasedId/v1":"290495d5be21dbdf23b4493bd93a7c27be13a817c01e5612e107d6e44a70dd0e7f1ed123452bb3a65bb40c65aa2ff2a8bcd414d261f937d71d8bc82401c5b5b8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":24,"snippet":{"text":"exports.handler = function(event, context) {\n  // ruleid: dynamodb-request-object\n  documentClient.query(event.body.params, function(err, data) {\n    if (err) {\n      console.log(err);\n    }\n    console.log(data);\n  });\n}\n\nexports.handler = function(event, context) {\n  const params = Object.assign({hardcoded: 'params'}, event.body.params)\n  // ruleid: dynamodb-request-object\n  documentClient.query(params, function(err, data) {\n    if (err) {\n      console.log(err);\n    }\n    console.log(data);\n  });\n}"},"startColumn":1,"startLine":5}}}],"message":{"text":"`exports.handler` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"c5e7d571a6ba10159a078c8dfeb2bcf59e5f3bf68bd81fde0fe14037afd881a5e4b6e7a276798a1300e571ae30432facbe6b01a650bdb43730d40ed2a7ff776a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":41,"endLine":7,"snippet":{"text":"  documentClient.query(event.body.params, function(err, data) {"},"startColumn":24,"startLine":7}}}],"message":{"text":"Detected DynamoDB query params that are tainted by `event` object. This could lead to NoSQL injection if the variable is user-controlled and not properly sanitized. Explicitly assign query params instead of passing data from `event` directly to DynamoDB client."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.dynamodb-request-object"},{"fingerprints":{"matchBasedId/v1":"c6facefe460c32ce8afce150a2d1f96f64cfede6d8cc4a58674e8c02f526a7a8aa0cbf2567d7aaa236ad376c4d06c59a528bbd79849b49e31cfbfec24a9be67e_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":39,"snippet":{"text":"exports.handler = function(event, context) {\n  const params = Object.assign({hardcoded: 'params'}, event.body.params)\n  // ruleid: dynamodb-request-object\n  documentClient.query(params, function(err, data) {\n    if (err) {\n      console.log(err);\n    }\n    console.log(data);\n  });\n}\n\nexports.handler = function(event, context) {\n  // ok: dynamodb-request-object\n  documentClient.query({\n    // this is stupid, but we do not interested in such findings for this rule\n    FilterExpression: `${event.body.name} = :s`,\n    ExpressionAttributeValues: {\n      \":s\": { N: \"1\" }\n    },\n    KeyConditionExpression: 'STRING_VALUE'\n  }, function(err, data) {\n    if (err) console.log(err);\n    else console.log(data);\n  });\n}"},"startColumn":1,"startLine":15}}}],"message":{"text":"`exports.handler` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"b4e8e2323ae814ae221cf7c9d6db8af3ca7c9ed5552e994e00fc5228e89aa30f5909c66fa65e335f372f526fdfefefee85ea1e20a5e02704354dbb1c251130e7_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":73,"endLine":16,"snippet":{"text":"  const params = Object.assign({hardcoded: 'params'}, event.body.params)"},"startColumn":18,"startLine":16}}}],"message":{"text":"Depending on the context, user control data in `Object.assign` can cause web response to include data that it should not have or can lead to a mass assignment vulnerability."},"properties":{},"ruleId":"opengrep-rules.express.security.express-data-exfiltration"},{"fingerprints":{"matchBasedId/v1":"365e4ad115053b24f0c3e67d1fe9916995f3fd094a5193acda5597cdd5c2433327bd7fcd12df6f236fc3bc0e60704c12fc3d9cb6d49bd91c03414bbea853b131_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":18,"snippet":{"text":"  documentClient.query(params, function(err, data) {"},"startColumn":24,"startLine":18}}}],"message":{"text":"Detected DynamoDB query params that are tainted by `event` object. This could lead to NoSQL injection if the variable is user-controlled and not properly sanitized. Explicitly assign query params instead of passing data from `event` directly to DynamoDB client."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.dynamodb-request-object"},{"fingerprints":{"matchBasedId/v1":"257d4b2af9a8bd91f1fe70cec67bd4e92da78227814479caf5ef82670f3bc8f449f045034489bb83bb71515804f62624d1e27b08d2e61a17b3efce2a52787237_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":80,"endLine":42,"snippet":{"text":"const { DynamoDBClient, QueryCommand } = require(\"@aws-sdk/client-dynamodb\");\nconst { DynamoDBDocumentClient, PutCommand } = require(\"@aws-sdk/lib-dynamodb\");"},"startColumn":1,"startLine":41}}}],"message":{"text":"`const` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"0c3020230e9000ad204c2d0c6b8920e287160d5503b987357d9dc8bed700dd47c84b6a0bfd7f41c8141335716b5196dfcf0dcbdb3015072da250492056c46c3f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":64,"snippet":{"text":"exports.handler = function(event, context) {\n\n  const ddbClient = new DynamoDBClient({ region: 'REGION' });\n  const ddbDocClient = DynamoDBDocumentClient.from(ddbClient);\n  const { params } = event.body\n  // todoruleid: dynamodb-request-object\n  const data = await ddbDocClient.send(new QueryCommand(params));\n  console.log(\"Success:\", data.Items);\n\n}\n\nexports.handler = function(event, context) {\n\n  const ddbClient = new DynamoDBClient({ region: 'REGION' });\n  const ddbDocClient = DynamoDBDocumentClient.from(ddbClient);\n  const params = event.body.params\n  // ruleid: dynamodb-request-object\n  const data = await ddbDocClient.send(new QueryCommand(params));\n  console.log(\"Success:\", data.Items);\n\n}"},"startColumn":1,"startLine":44}}}],"message":{"text":"`exports.handler` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"380361eadbc755dbe997d6547f2ae70256f4d78d1d2fbcfd9e3c13c7bf4de1b5fc6af6cbd7a7d56634287030a875d28a2f384c2666227c49463aa51f41b63c9c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":81,"snippet":{"text":"exports.handler = function(event, context) {\n\n  const ddbClient = new DynamoDBClient({ region: 'REGION' });\n  const ddbDocClient = DynamoDBDocumentClient.from(ddbClient);\n  const params = event.body.params\n  // ruleid: dynamodb-request-object\n  const data = await ddbDocClient.send(new QueryCommand(params));\n  console.log(\"Success:\", data.Items);\n\n}\n\nexports.handler = function(event, context) {\n\n  const ddbClient = new DynamoDBClient({ region: 'REGION' });\n  const ddbDocClient = DynamoDBDocumentClient.from(ddbClient);\n  const params = {\n    KeyConditionExpression: \"Title = :s\",\n    ExpressionAttributeValues: {\n      \":s\": { S: event.body.title }\n    },\n    ProjectionExpression: \"Episode, Title\",\n    TableName: \"TVSHOWS\",\n  }\n  // ok: dynamodb-request-object\n  const data = await ddbDocClient.send(new QueryCommand(params));\n  console.log(\"Success:\", data.Items);\n}"},"startColumn":1,"startLine":55}}}],"message":{"text":"`exports.handler` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"a4b288f1d8367a8c2c6e0b8af42221baf906bc76884c24189c1d88f41ac9952d2c5c7858299332a52645849e660832a4afb3423976e78459245a57745aa36c2a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/dynamodb-request-object.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":64,"endLine":61,"snippet":{"text":"  const data = await ddbDocClient.send(new QueryCommand(params));"},"startColumn":40,"startLine":61}}}],"message":{"text":"Detected DynamoDB query params that are tainted by `event` object. This could lead to NoSQL injection if the variable is user-controlled and not properly sanitized. Explicitly assign query params instead of passing data from `event` directly to DynamoDB client."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.dynamodb-request-object"},{"fingerprints":{"matchBasedId/v1":"03cd6b0d94ec9d20f57190182ddb5e5556b15ce62fa9122dacdc1c52b721a706003b03c5eca971931bddaf239dae7136e869f8f17cb989a183b1996d64e1889b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/knex-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":6,"endLine":25,"snippet":{"text":"  await connection.raw(`\n    INSERT INTO  (id, character, cartoon, link)\n    VALUES(\n        '${event.id}', \n        '${event.character}',\n        '${event.cartoon}', \n        '${event.link}'\n    )\n    `);"},"startColumn":24,"startLine":17}}}],"message":{"text":"Detected SQL statement that is tainted by `event` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `knex.raw('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.knex-sqli"},{"fingerprints":{"matchBasedId/v1":"cdc086046df820c746f7fcee5cfab4b8c52bd12ac8870d2a1290fab8373dd1a58732cf856028ba491f52efaf8505fd1cc6beee25398a14568197fbebd5909536_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/mysql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":53,"endLine":31,"snippet":{"text":"  var createStmt = 'create temporary table ' + table + '_jointemp (temp_seq int, '+ columnName + ' varchar(100)); ';"},"startColumn":20,"startLine":31}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"a5e36bc8b1611f5b343ce7c36aab43cc87d315623b5ca977537d38d1ff31a4ecf1d1ba13696078e3946d8d2eee9efe4da340414b716f98e404916649d401e5e2_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/mysql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":33,"snippet":{"text":"  await conn.query(createStmt);"},"startColumn":20,"startLine":33}}}],"message":{"text":"Detected SQL statement that is tainted by `event` object. This could lead to SQL injection if the variable is user-controlled and not properly sanitized. In order to prevent SQL injection, use parameterized queries or prepared statements instead. You can use parameterized statements like so: `connection.query('SELECT $1 from table', [userinput])`"},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.mysql-sqli"},{"fingerprints":{"matchBasedId/v1":"6567a804d19c0ec4b2a2c08066bad638f0dc5197d2ce5872c9cfdf5316904c6917745c0450304e4b4130dade0b32df2f9d3475f38a530be555e7bd8ce7c8090a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/mysql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":30,"endLine":33,"snippet":{"text":"  await conn.query(createStmt);"},"startColumn":20,"startLine":33}}}],"message":{"text":"Detected a `mysql2` SQL statement that comes from a function argument. This could lead to SQL injection if the variable is user-controlled and is not properly sanitized. In order to prevent SQL injection, it is recommended to use parameterized queries or prepared statements."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.sqli.node-mysql-sqli"},{"fingerprints":{"matchBasedId/v1":"52ca541f5f5a419ed90be7431bb818d6114e0004472aa9c8d33da9071f26d31b4bd746f66807165cb32436a33198ce32682845b542885ce9c18db1b56a32f4a3_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/aws-lambda/security/mysql-sqli.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":42,"endLine":37,"snippet":{"text":"  var insertStmt = 'insert into ' + table + '_jointemp(temp_seq, '+ columnName +') values ' + values.join(',') + ';';"},"startColumn":20,"startLine":37}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.aws-lambda.security.tainted-sq