 for remote repositories. For example, git clone 'ext::sh -c whoami% >&2' will execute the whoami command to try to connect to a remote repository. Make sure that the URL is not controlled by external input."},"properties":{},"ruleId":"opengrep-rules.lang.security.spawn-git-clone"},{"fingerprints":{"matchBasedId/v1":"f6af2c2ba014f20f2a965df713d1935eaa92b0d0cf82ecea47b82b84d919ddb182b014c92a401e980594b46b631701026f8dde3426c35582e9d01421c2b68500_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/spawn-git-clone.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":50,"endLine":17,"snippet":{"text":"    const childProcess = require('child_process');"},"startColumn":26,"startLine":17}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"50e78a4222a207c1ef401c49fefce48de8d51792f99b6b6c60e1b92d9ba20f50d40e62ccf417ee35120432ec1e93f9382f8fdbd9c1d449940b94985c02965ed8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/spawn-git-clone.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":11,"endLine":24,"snippet":{"text":"        const gitClone = childProcess.spawn('git', [\n            'clone',\n            '--depth', '1',\n            req.body.gitUrl\n        ]);"},"startColumn":26,"startLine":20}}}],"message":{"text":"Git allows shell commands to be specified in ext URLs for remote repositories. For example, git clone 'ext::sh -c whoami% >&2' will execute the whoami command to try to connect to a remote repository. Make sure that the URL is not controlled by external input."},"properties":{},"ruleId":"opengrep-rules.lang.security.spawn-git-clone"},{"fingerprints":{"matchBasedId/v1":"68383eaa89bca076b39c6928a99f2f9ed754f5c7247a3878dcaa7028149e53eb794b63dbf98eaf35d8f040a580a2068665aa361f544a71a3600c5df317360771_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/spawn-git-clone.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":50,"endLine":30,"snippet":{"text":"    const childProcess = require('child_process');"},"startColumn":26,"startLine":30}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"d9ae4199a2cf2e0ac53747411f4f43308ad5c84ffa9a40e1f17b596f023f16dff794c68d6267044472bd35ceeef4505359fb7a295f301ed928d2622d5ad001c6_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/spawn-git-clone.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":72,"endLine":33,"snippet":{"text":"        const gitClone = childProcess.spawn('git', [ 'clone', gitUrl ]);"},"startColumn":26,"startLine":33}}}],"message":{"text":"Git allows shell commands to be specified in ext URLs for remote repositories. For example, git clone 'ext::sh -c whoami% >&2' will execute the whoami command to try to connect to a remote repository. Make sure that the URL is not controlled by external input."},"properties":{},"ruleId":"opengrep-rules.lang.security.spawn-git-clone"},{"fingerprints":{"matchBasedId/v1":"834c0a896afb1ad42ce9272f7edb7dcedd70ed79de65b0d9e02e98f45f3c4045bbc5578afff0dafdb4ba94863d2890ff76e9da8d9b6d0372643703621e9ced41_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/spawn-git-clone.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":39,"snippet":{"text":"    const { spawn } = require('child_process');"},"startColumn":23,"startLine":39}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"ef9c91915ede0a6d7d4cc1d61f56ca869b52633275c8fa2cf2bd418d1b36e8245a80f0e0627f4e821f25aed0f24e7078a91aac713fc249ca271066b33b386caf_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/spawn-git-clone.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":50,"endLine":48,"snippet":{"text":"    const childProcess = require('child_process');"},"startColumn":26,"startLine":48}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"733447dd5ad9e83f2d252689a5fa161ecf3c2d5c8b166c6979d8b647d34dbada8432a864f2e75fa78db06cabd74ea31777208f74e2e5dd5b351e5a99de0d28fc_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/monaco-editor/security/audit/monaco-hover-htmlsupport.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":12,"endLine":14,"snippet":{"text":"          {\n            value: `<a href=\"${userInput}\">Hello</a>`,\n            supportHtml: true,\n            isTrusted: true\n          },"},"startColumn":11,"startLine":10}}}],"message":{"text":"If user input reaches `HoverProvider` while `supportHml` is set to `true` it may introduce an XSS vulnerability. Do not produce HTML for hovers with dynamically generated input."},"properties":{},"ruleId":"opengrep-rules.monaco-editor.security.audit.monaco-hover-htmlsupport"},{"fingerprints":{"matchBasedId/v1":"77c2ed4b99572c97fd433c76e374f6ae0bae1499a5a3d1fd9bd4b2f8ad9306c6fe1a94724fdf37f842ed481d1a5c6b6138760b1225ef825bd867e0ace2c4511d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/monaco-editor/security/audit/monaco-hover-htmlsupport.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":54,"endLine":11,"snippet":{"text":"            value: `<a href=\"${userInput}\">Hello</a>`,"},"startColumn":20,"startLine":11}}}],"message":{"text":"This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."},"properties":{},"ruleId":"opengrep-rules.lang.security.html-in-template-string"},{"fingerprints":{"matchBasedId/v1":"89882704fdf12a0d70dbf3d76ed57e05db1a28406246a1e5fb644195bee282aa2619ce78863be72e58fa31a8d276a2641a3bf2cc431f75a70b0570ea5c81cef8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":48,"endLine":8,"snippet":{"text":"    const decipher = crypto.createDecipheriv(\"aes-128-gcm\", key, iv);\n    let result = decipher.update(encryptedData);"},"startColumn":5,"startLine":7}}}],"message":{"text":"The 'final' call of a Decipher object checks the authentication tag in a mode for authenticated encryption. Failing to call 'final' will invalidate all integrity guarantees of the released ciphertext."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.aead-no-final"},{"fingerprints":{"matchBasedId/v1":"e7555a077e8487db9f8ba2e0bf06e0c5ded59d713a2ca587b8f5d104ef91da676bc696ab2468e4d734edbd5a42efa9c67e3230dc67786a12fc6440c8ddece011_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":69,"endLine":7,"snippet":{"text":"    const decipher = crypto.createDecipheriv(\"aes-128-gcm\", key, iv);"},"startColumn":22,"startLine":7}}}],"message":{"text":"The call to 'createDecipheriv' with the Galois Counter Mode (GCM) mode of operation is missing an expected authentication tag length. If the expected authentication tag length is not specified or otherwise checked, the application might be tricked into verifying a shorter-than-expected authentication tag. This can be abused by an attacker to spoof ciphertexts or recover the implicit authentication key of GCM, allowing arbitrary forgeries."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.gcm-no-tag-length"},{"fingerprints":{"matchBasedId/v1":"e3b76fc2e38f069d0c446ff72161102ba8966e1f90049e18a49b6c4657b465d47aedb172ac3ad7a8ef8b8738e6e39d25208f7bd3ed4c2f059c62a120048e1476_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":48,"endLine":22,"snippet":{"text":"    var decipher = crypto.createDecipheriv(algo, key, iv);\n    decipher.setAuthTag(auth);\n    let result = decipher.update(encryptedData);"},"startColumn":5,"startLine":20}}}],"message":{"text":"The 'final' call of a Decipher object checks the authentication tag in a mode for authenticated encryption. Failing to call 'final' will invalidate all integrity guarantees of the released ciphertext."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.aead-no-final"},{"fingerprints":{"matchBasedId/v1":"71a48afe29345bc2ea04ab21fae2a1624c80b326050fd21c1f8c386245d28aacf84ded6d78ee6bf495e67820a6436591c32f59cc5851f5937bd175aa869308ac_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":58,"endLine":20,"snippet":{"text":"    var decipher = crypto.createDecipheriv(algo, key, iv);"},"startColumn":20,"startLine":20}}}],"message":{"text":"The call to 'createDecipheriv' with the Galois Counter Mode (GCM) mode of operation is missing an expected authentication tag length. If the expected authentication tag length is not specified or otherwise checked, the application might be tricked into verifying a shorter-than-expected authentication tag. This can be abused by an attacker to spoof ciphertexts or recover the implicit authentication key of GCM, allowing arbitrary forgeries."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.gcm-no-tag-length"},{"fingerprints":{"matchBasedId/v1":"2f7067e5998c617eb06503082771cb3dd7421376b3347ab31b0352b3883445af484ca1f1bddd36184c66d5fb61fd8f5ab2f56622cae4809eafc481615308bbec_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":48,"endLine":36,"snippet":{"text":"    const decipher = crypto.createDecipheriv(\"aes-256-ccm\", key, iv, {authTagLength: 16})\n    decipher.setAuthTag(auth)\n    decipher.setAAD(Buffer.alloc(0), {plaintextLength: encryptedData.length})\n    let result = decipher.update(encryptedData)"},"startColumn":5,"startLine":33}}}],"message":{"text":"The 'final' call of a Decipher object checks the authentication tag in a mode for authenticated encryption. Failing to call 'final' will invalidate all integrity guarantees of the released ciphertext."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.aead-no-final"},{"fingerprints":{"matchBasedId/v1":"e0c2f94642bf3f5a20258f9edf160f711266ef043d415683b0e5bcbda89bd123717a65e5390ac66a06e1ea0c605ebbc97c4b0c615a927d7ac15b74704699e540_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":88,"endLine":47,"snippet":{"text":"    let decipher = crypto.createDecipheriv(\"aes-256-ocb\", key, iv, {authTagLength: 16});\n    let decrypted = decipher.update(encrypted.slice(0, encrypted.byteLength - 16 - 12));"},"startColumn":5,"startLine":46}}}],"message":{"text":"The 'final' call of a Decipher object checks the authentication tag in a mode for authenticated encryption. Failing to call 'final' will invalidate all integrity guarantees of the released ciphertext."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.aead-no-final"},{"fingerprints":{"matchBasedId/v1":"c838f3249a4bc5e730e89713d43b94b1af214626ecee81881a1387c7f83e5a3b80eecde2b2c96fc0030a99be6220d1a0d5848b4406c93d705a471a88b22206bc_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":90,"endLine":59,"snippet":{"text":"    let decipher = createDecipheriv(\"chacha20-poly1305\", key, iv);\n    let decrypted = decipher.update(ciphertext.slice(0, ciphertext.byteLength - 16 - 12));"},"startColumn":5,"startLine":58}}}],"message":{"text":"The 'final' call of a Decipher object checks the authentication tag in a mode for authenticated encryption. Failing to call 'final' will invalidate all integrity guarantees of the released ciphertext."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.aead-no-final"},{"fingerprints":{"matchBasedId/v1":"e7555a077e8487db9f8ba2e0bf06e0c5ded59d713a2ca587b8f5d104ef91da676bc696ab2468e4d734edbd5a42efa9c67e3230dc67786a12fc6440c8ddece011_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/aead-no-final.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":67,"endLine":71,"snippet":{"text":"    var decipher = crypto.createDecipheriv(\"aes-128-gcm\", key, iv);"},"startColumn":20,"startLine":71}}}],"message":{"text":"The call to 'createDecipheriv' with the Galois Counter Mode (GCM) mode of operation is missing an expected authentication tag length. If the expected authentication tag length is not specified or otherwise checked, the application might be tricked into verifying a shorter-than-expected authentication tag. This can be abused by an attacker to spoof ciphertexts or recover the implicit authentication key of GCM, allowing arbitrary forgeries."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.gcm-no-tag-length"},{"fingerprints":{"matchBasedId/v1":"07a9cfcce2628b221b8345689b45dc7d29b24b2e3b8fd0d646cde41a118c18b8aa33900ec9e0aba7fc49d720cb1adde28a1f87d6561f361fb2340c92727b238c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/create-de-cipher-no-iv.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":67,"endLine":7,"snippet":{"text":"    const decipher = crypto.createDecipher(\"aes-128-gcm\", key, iv);"},"startColumn":22,"startLine":7}}}],"message":{"text":"The deprecated functions 'createCipher' and 'createDecipher' generate the same initialization vector every time. For counter modes such as CTR, GCM, or CCM this leads to break of both confidentiality and integrity, if the key is used more than once. Other modes are still affected in their strength, though they're not completely broken. Use 'createCipheriv' or 'createDecipheriv' instead."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.create-de-cipher-no-iv"},{"fingerprints":{"matchBasedId/v1":"07a9cfcce2628b221b8345689b45dc7d29b24b2e3b8fd0d646cde41a118c18b8aa33900ec9e0aba7fc49d720cb1adde28a1f87d6561f361fb2340c92727b238c_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/create-de-cipher-no-iv.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":61,"endLine":18,"snippet":{"text":"    var decipher = crypto.createDecipher(\"aes-192-cbc\", key);"},"startColumn":20,"startLine":18}}}],"message":{"text":"The deprecated functions 'createCipher' and 'createDecipher' generate the same initialization vector every time. For counter modes such as CTR, GCM, or CCM this leads to break of both confidentiality and integrity, if the key is used more than once. Other modes are still affected in their strength, though they're not completely broken. Use 'createCipheriv' or 'createDecipheriv' instead."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.create-de-cipher-no-iv"},{"fingerprints":{"matchBasedId/v1":"aaf972866a7ca916fff5ab4bc37d86317ba6ff71b497d3bc1d51335d9488713642a2d2567c5c4ac15c8670d1d7b1a19e4d2a693f828e20636476102c7037039a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/create-de-cipher-no-iv.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":73,"endLine":27,"snippet":{"text":"    const cipher = createCipher(\"aes-256-ccm\", key, {authTagLength: 16})"},"startColumn":20,"startLine":27}}}],"message":{"text":"The deprecated functions 'createCipher' and 'createDecipher' generate the same initialization vector every time. For counter modes such as CTR, GCM, or CCM this leads to break of both confidentiality and integrity, if the key is used more than once. Other modes are still affected in their strength, though they're not completely broken. Use 'createCipheriv' or 'createDecipheriv' instead."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.create-de-cipher-no-iv"},{"fingerprints":{"matchBasedId/v1":"9a1b527e443a2ffd042fbb96a18a450d33e50c4d3a6869c7463666a24459bf302b3a67d67f2e46bee4ce9c6767bcd39b0c8e0ab86dec05b390d46bd3324ae7bb_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/create-de-cipher-no-iv.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":88,"endLine":40,"snippet":{"text":"    let decipher = crypto.createDecipheriv(\"aes-256-ocb\", key, iv, {authTagLength: 16});\n    let decrypted = decipher.update(encrypted.slice(0, encrypted.byteLength - 16 - 12));"},"startColumn":5,"startLine":39}}}],"message":{"text":"The 'final' call of a Decipher object checks the authentication tag in a mode for authenticated encryption. Failing to call 'final' will invalidate all integrity guarantees of the released ciphertext."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.aead-no-final"},{"fingerprints":{"matchBasedId/v1":"fae11cb852dfed64e146607879a77d6a368e010e76bd45080838307e1cd5010220de6b537708792193fa81f472b18755713f198083fc7eb44aedf354cb521817_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/gcm-no-tag-length.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":60,"endLine":10,"snippet":{"text":"    const decipher = crypto.createDecipheriv(algo, key, iv);"},"startColumn":22,"startLine":10}}}],"message":{"text":"The call to 'createDecipheriv' with the Galois Counter Mode (GCM) mode of operation is missing an expected authentication tag length. If the expected authentication tag length is not specified or otherwise checked, the application might be tricked into verifying a shorter-than-expected authentication tag. This can be abused by an attacker to spoof ciphertexts or recover the implicit authentication key of GCM, allowing arbitrary forgeries."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.gcm-no-tag-length"},{"fingerprints":{"matchBasedId/v1":"55492879f6d1ecc552ac64876fd2e3ddbd9c4e739b0f9ebceb51dc055836463402181e84ba41dcf1ff803dae596a1fb446ab7d5721282d9dc8468b060289e729_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-crypto/security/gcm-no-tag-length.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":69,"endLine":25,"snippet":{"text":"    const decipher = crypto.createDecipheriv(\"aes-192-gcm\", key, iv);"},"startColumn":22,"startLine":25}}}],"message":{"text":"The call to 'createDecipheriv' with the Galois Counter Mode (GCM) mode of operation is missing an expected authentication tag length. If the expected authentication tag length is not specified or otherwise checked, the application might be tricked into verifying a shorter-than-expected authentication tag. This can be abused by an attacker to spoof ciphertexts or recover the implicit authentication key of GCM, allowing arbitrary forgeries."},"properties":{},"ruleId":"opengrep-rules.node-crypto.security.gcm-no-tag-length"},{"fingerprints":{"matchBasedId/v1":"e978c58074c4e0e14747f8ec28a143382cc8b2b825f6ca23997974a99bdd519d6abe33e2550ae8f214fdeea42991d544c847bf0eb9ae88592e532479973a2cba_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-expat/security/audit/expat-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":5,"snippet":{"text":"    var expat = require('node-expat')\n    var parser = new expat.Parser('UTF-8')\n    parser.parse(input)"},"startColumn":5,"startLine":3}}}],"message":{"text":"If unverified user data can reach the XML Parser it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.node-expat.security.audit.expat-xxe"},{"fingerprints":{"matchBasedId/v1":"5e4f3bb83c9cda30e9e78924458b7811718509c848ced37ee09e7d6a24cddde0448a07d2cb259967f775ec5530b46aa75ed23693776f9f6bb05e9d552bea4d23_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-expat/security/audit/expat-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":38,"endLine":3,"snippet":{"text":"    var expat = require('node-expat')"},"startColumn":17,"startLine":3}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"fdf64fdaed30e03a922332ad3334b6ed8dc0914883b5f36838215dbf01a4b1d77850ad3bc94e8017a917ba2d71c8ad5ad2fcc43fcec8beb67857f44d0bcd086d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-expat/security/audit/expat-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":12,"snippet":{"text":"    const {Parser} = require('node-expat')\n    const parser = new Parser('UTF-8')\n    parser.write(input)"},"startColumn":5,"startLine":10}}}],"message":{"text":"If unverified user data can reach the XML Parser it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.node-expat.security.audit.expat-xxe"},{"fingerprints":{"matchBasedId/v1":"427b25225a7f4badbd671162409e8238b1d71819fd28c54604d94742a236884dd923e965025e1f73361aacbe9899fd4c86064389eaa505dd5042cf79edfb6072_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/node-expat/security/audit/expat-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":43,"endLine":10,"snippet":{"text":"    const {Parser} = require('node-expat')"},"startColumn":22,"startLine":10}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"2c0207b917cffd35fc0509cad436b2e5577307cd61d912c155a32d66b5e4823b298f91fd985b97cd135c7fbc76313b7fbf940094c7c8d231f6cf1e2fcede725f_0"},"locations":[{"physicalLocation":{"artifact