way set to True (default value). With self -signed certificate or custom CA, use \"ca\" option to define Root Certificate. This rule checks TLS configuration only for Postgresql, MariaDB and MySQL. SQLite is not really concerned by TLS configuration. This rule could be extended for MSSQL, but the dialectOptions is specific for Tedious."},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-tls-disabled-cert-validation"},{"fingerprints":{"matchBasedId/v1":"58fb445b211c207fd46a23168d613dcadec3eb39e7a129331921b728f0aecff5d23229d50ffaa4a27ea7e9df9a658c1d8765282994aa37561488a097e08d2072_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-tls-disabled-cert-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":64,"snippet":{"text":"  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n  }"},"startColumn":8,"startLine":59}}}],"message":{"text":"If TLS is disabled on server side (Postgresql server), Sequelize establishes connection without TLS and no error will be thrown. To prevent MITN (Man In The Middle) attack, TLS must be enforce by Sequelize. Set \"ssl: true\" or define settings \"ssl: {...}\""},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-enforce-tls"},{"fingerprints":{"matchBasedId/v1":"4de1b7a99a6d4049cd6687567f59217636dae141bed7067b143608eda5be7830477261795e9e057ee892c13eb2a90236b2a5c8512d479d805f903dec8b2867dc_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-weak-tls-version.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":29,"snippet":{"text":"module.exports = {\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n    // ruleid: sequelize-weak-tls-version\n      ssl: {\n        minVersion: 'TLSv1'\n      }\n    }\n  }\n};\n\nmodule.exports = {\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n    // ruleid: sequelize-weak-tls-version\n      ssl: {\n        minVersion: 'TLSv1.1'\n      }\n    }\n  }\n};"},"startColumn":1,"startLine":1}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"c3e8b0a39f9983ff79b9b4e943c7dd975a5b55684d1a7e7af9b20e3460987addd2301c47af4bc8293916282ff30a0af6e84ce2bbb8943046ffd36aaf7f016d69_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-weak-tls-version.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":8,"endLine":11,"snippet":{"text":"      ssl: {\n        minVersion: 'TLSv1'\n      }"},"startColumn":12,"startLine":9}}}],"message":{"text":"TLS1.0 and TLS1.1 are deprecated and should not be used anymore. By default, NodeJS used TLSv1.2. So, TLS min version must not be downgrade to TLS1.0 or TLS1.1. Enforce TLS1.3 is highly recommended This rule checks TLS configuration only for PostgreSQL, MariaDB and MySQL. SQLite is not really concerned by TLS configuration. This rule could be extended for MSSQL, but the dialectOptions is specific for Tedious."},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-weak-tls-version"},{"fingerprints":{"matchBasedId/v1":"0e03a3163ff4da2c623634f14efcde324e6d7e312010e8a7b16f06d6c62b45484a04aa3eab9fdf1e18fc67e4e7c9a7d5689136d574b9f156203e9c6cd7fa6b27_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-weak-tls-version.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":44,"snippet":{"text":"module.exports = {\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\