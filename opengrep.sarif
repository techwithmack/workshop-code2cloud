 by the addEventListener API. It may be possible to exploit this flaw to perform Cross Origin attacks such as Cross-Site Scripting(XSS)."},"properties":{},"ruleId":"opengrep-rules.browser.security.insufficient-postmessage-origin-validation"},{"fingerprints":{"matchBasedId/v1":"947195ca89e9b8c1ec4d315a05825b0893f21fbf399bc7a481102fa055d1b9c81ccf5e6cbd8ab2fa4983a6c31f9675fe2a94c213937320b0d4376a87e545ae86_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/insufficient-postmessage-origin-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":16,"snippet":{"text":"window.addEventListener('message', (evt) => {\n  console.log('Inline arrow function without origin check!');\n});"},"startColumn":1,"startLine":14}}}],"message":{"text":"No validation of origin is done by the addEventListener API. It may be possible to exploit this flaw to perform Cross Origin attacks such as Cross-Site Scripting(XSS)."},"properties":{},"ruleId":"opengrep-rules.browser.security.insufficient-postmessage-origin-validation"},{"fingerprints":{"matchBasedId/v1":"4a48dc2e6b8fa849aba48b902fb4b99e86e605e2c301e5e67b87de65a657b577ca6a6e092769ab2c9a47c609c1e927e6bd3da0ca4538e1b0ccae16b383a6c83b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/browser/security/insufficient-postmessage-origin-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":21,"snippet":{"text":"window.addEventListener('message', evt => {\n  console.log('Inline arrow function without parenthesis & origin check!');\n});"},"startColumn":1,"startLine":19}}}],"message":{"text":"No validation of origin is done by the addEventListener API. It may be possible to exploit this flaw to perform Cross Origin attacks such as Cross-Site Scripting(XSS)."},"properties":{},"ruleId":"opengrep-rules.browser.security.insufficient-postmessage-origin-validation"},{"fingerprints":{"matchBasedId/v1":"31e1cd80846c3dbef66181712a546afb091f24dbf5d6