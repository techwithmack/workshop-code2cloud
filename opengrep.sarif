"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"504f43c4602d1883d46ab1371bf802f362c6293a2a16a9ff814e9004b13d2ce9dfb380015ad43d6f621061e2b28889de4e3465b552819c534191ba1f85764438_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":2,"snippet":{"text":"const app = express()"},"startColumn":7,"startLine":2}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"62e3a0c2e9b17079317ef78a91b5bc5879fffeb66f29f4d03d37c2aff2ea539dbb694d15da520e0d65f9453faf437860858867edfe138fb7207c9c24fd2e884f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":46,"endLine":10,"snippet":{"text":"        require(req.query.controllerFullPath)(req, res);"},"startColumn":9,"startLine":10}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"5bd625e13643f834863cdb7b999f6b6b8895e2b68f80460f06183c322c998dc65fac1e809d4d8f66224aa5d0786ce7d214bbedc14fe1c27b1aaa3ce16c5c2359_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":46,"endLine":10,"snippet":{"text":"        require(req.query.controllerFullPath)(req, res);"},"startColumn":9,"startLine":10}}}],"message":{"text":"Detected the use of require(variable). Calling require with a non-literal argument might allow an attacker to load and run arbitrary code, or access arbitrary files."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-require"},{"fingerprints":{"matchBasedId/v1":"b6561d238f0e2b58c1d42402604d574ae04c928ab04d2a8316379396a61b063beb6291175b4d21f71d7dbca1d47ea3870bd65705763da99cc4768d3eb31904a2_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":45,"endLine":10,"snippet":{"text":"        require(req.query.controllerFullPath)(req, res);"},"startColumn":17,"startLine":10}}}],"message":{"text":"If an attacker controls the x in require(x) then they can cause code to load that was not intended to run on the server."},"properties":{},"ruleId":"opengrep-rules.express.security.require-request"},{"fingerprints":{"matchBasedId/v1":"85e0ecfc34ffe03852c3628410d01b3db11b32a75b85bd9a3ae34f637953685fbd7cca9523a93818ad62a96021b262ff00bc4b35e3c37446cfcee78d5dc88b12_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":20,"snippet":{"text":"    const func = require(req.body)"},"startColumn":18,"startLine":20}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"5bd625e13643f834863cdb7b999f6b6b8895e2b68f80460f06183c322c998dc65fac1e809d4d8f66224aa5d0786ce7d214bbedc14fe1c27b1aaa3ce16c5c2359_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":20,"snippet":{"text":"    const func = require(req.body)"},"startColumn":18,"startLine":20}}}],"message":{"text":"Detected the use of require(variable). Calling require with a non-literal argument might allow an attacker to load and run arbitrary code, or access arbitrary files."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-require"},{"fingerprints":{"matchBasedId/v1":"6d7b1a99ae77749a62cd76a69c726b33eed84d5ba6ae5528860c9081952171f2447b30387912a29fc3479f6dd149f64cd8ca1f2dc1600c2c940d543cf2e40e0d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":34,"endLine":20,"snippet":{"text":"    const func = require(req.body)"},"startColumn":26,"startLine":20}}}],"message":{"text":"If an attacker controls the x in require(x) then they can cause code to load that was not intended to run on the server."},"properties":{},"ruleId":"opengrep-rules.express.security.require-request"},{"fingerprints":{"matchBasedId/v1":"bdf91168e7be01aea6f1555727d62b920d8378a1ef6b082bfb9877ae6b8309491c9e84b4ae5e65216b8271547016c1248e109ebe7fbb2d7364a9df2c5e9fe69d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":27,"endLine":21,"snippet":{"text":"    return res.send(func())"},"startColumn":21,"startLine":21}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"7128310738084cb805b445bf855eab6cfa6294c3e0aa55f59fd7c6da6020e4522e825613de5331c6a893d970caf8d7cc97ea3a5ab57cc6a865affa7454dd236b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":30,"snippet":{"text":"var testController3 = null;\ntestController3 = function (req, res) {\n    // ruleid: require-request\n    const func = require(req.body)\n    return res.send(func())\n}"},"startColumn":1,"startLine":25}}}],"message":{"text":"`testController3` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"5bd625e13643f834863cdb7b999f6b6b8895e2b68f80460f06183c322c998dc65fac1e809d4d8f66224aa5d0786ce7d214bbedc14fe1c27b1aaa3ce16c5c2359_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":28,"snippet":{"text":"    const func = require(req.body)"},"startColumn":18,"startLine":28}}}],"message":{"text":"Detected the use of require(variable). Calling require with a non-literal argument might allow an attacker to load and run arbitrary code, or access arbitrary files."},"properties":{},"ruleId":"opengrep-rules.lang.security.audit.detect-non-literal-require"},{"fingerprints":{"matchBasedId/v1":"6d7b1a99ae77749a62cd76a69c726b33eed84d5ba6ae5528860c9081952171f2447b30387912a29fc3479f6dd149f64cd8ca1f2dc1600c2c940d543cf2e40e0d_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/require-request.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":34,"endLine":28,"snippet":{"