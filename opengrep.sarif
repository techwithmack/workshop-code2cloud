es/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":29,"snippet":{"text":"module.exports = {\n  // ruleid: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"mariadb\",\n    host: \"127.0.0.1\"\n  }\n};\n\nmodule.exports = {\n  // ruleid: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"mysql\",\n    host: \"127.0.0.1\"\n  }\n};"},"startColumn":1,"startLine":11}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"145dd38cafcf4984d34fa77adcdf95227ee2ba6c9c46c9e7cd82b728730025e1bfedf6dc0829176d8c2830af75044d950e0867ea70d1c83be9586c9ad7f741d9_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":18,"snippet":{"text":"  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"mariadb\",\n    host: \"127.0.0.1\"\n  }"},"startColumn":10,"startLine":13}}}],"message":{"text":"If TLS is disabled on server side (Postgresql server), Sequelize establishes connection without TLS and no error will be thrown. To prevent MITN (Man In The Middle) attack, TLS must be enforce by Sequelize. Set \"ssl: true\" or define settings \"ssl: {...}\""},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-enforce-tls"},{"fingerprints":{"matchBasedId/v1":"80444633f25e5e10b6595e2ce3f0015c420f2266deb49b651ff2284aaab0e5c169bab3d09791edb497cfcac30367f69c4dffe39345cc18780b44743ff5c8eec8_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":44,"snippet":{"text":"module.exports = {\n  // ruleid: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"mysql\",\n    host: \"127.0.0.1\"\n  }\n};\n\nmodule.exports = {\n  // ok: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        minVersion: 'TLSv1.3'\n      }\n    }\n  }\n};"},"startColumn":1,"startLine":21}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"5fdc50187201a7347764f744a348d391e677c0f6b1da39a05b75d6b0c0ec313a0f219b3f002a804b769f41b8905a83d4f02195fb1153b0f15233c6c61ec237dc_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":28,"snippet":{"text":"  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"mysql\",\n    host: \"127.0.0.1\"\n  }"},"startColumn":10,"startLine":23}}}],"message":{"text":"If TLS is disabled on server side (Postgresql server), Sequelize establishes connection without TLS and no error will be thrown. To prevent MITN (Man In The Middle) attack, TLS must be enforce by Sequelize. Set \"ssl: true\" or define settings \"ssl: {...}\""},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-enforce-tls"},{"fingerprints":{"matchBasedId/v1":"7adf1b515edd26a4fbc4fee84d2544cae208523a36e91b7677a630fcbee4d9e255e82f2d0460f4cb74997e963484796043ecfb465054f927429ccb81242967e0_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":57,"snippet":{"text":"module.exports = {\n  // ok: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        minVersion: 'TLSv1.3'\n      }\n    }\n  }\n};\n\nmodule.exports = {\n  // ok: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: true\n    }\n  }\n};"},"startColumn":1,"startLine":31}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"714a832ac96ad5705d7e9c63f9ce4fc9762f6630e7443d714e4363f7106d402fc6fac7b3a4562ed3e6a320c429a116e6e48331c5a93340d00c275898711d38b9_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":70,"snippet":{"text":"module.exports = {\n  // ok: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: true\n    }\n  }\n};\n\nmodule.exports = {\n  // ruleid: sequelize-enforce-tls\n  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: false\n    }\n  }\n};"},"startColumn":1,"startLine":46}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"caf084171eeabd58a1b10a643310d371815f5be214320d4e887dee7b4e1fd487d84e2ec6fcd197da8e058614f156339ca239c3ad94251c8934402bb143116237_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-enforce-tls.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":69,"snippet":{"text":"  local: {\n    username: \"AppUser\",\n    database: \"AppDb\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: false\n    }\n  }"},"startColumn":10,"startLine":61}}}],"message":{"text":"If TLS is disabled on server side (Postgresql server), Sequelize establishes connection without TLS and no error will be thrown. To prevent MITN (Man In The Middle) attack, TLS must be enforce by Sequelize. Set \"ssl: true\" or define settings \"ssl: {...}\""},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-enforce-tls"},{"fingerprints":{"matchBasedId/v1":"9511c4c593cd5bd4639a9b731db5cce095d7c01cb98e7954fd01cd873d356d179acf3ac1d41982f81532d7e43e8e1c9f20a7fde2f7f245a9cf7f645a3aa3a6e4_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-injection-express.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":82,"endLine":34,"snippet":{"text":"    m.sequelize.query(`SELECT * FROM Foo WHERE ((criteria LIKE '%${criteria}%))`)"},"startColumn":5,"startLine":34}}}],"message":{"text":"Avoiding SQL string concatenation: untrusted input concatenated with raw SQL query can result in SQL Injection. Data replacement or data binding should be used. See https://sequelize.org/master/manual/raw-queries.html"},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-raw-query"},{"fingerprints":{"matchBasedId/v1":"3116454f6bdb1daf957633cafbacc921ae900da27a019a61d4f03590e395351d393bf3f15f7eb822ce78c918d114434df99dbc61d359347700b95c257b4eb92e_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-injection-express.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":81,"endLine":34,"snippet":{"text":"    m.sequelize.query(`SELECT * FROM Foo WHERE ((criteria LIKE '%${criteria}%))`)"},"startColumn":23,"startLine":34}}}],"message":{"text":"Detected a sequelize statement that is tainted by user-input. This could lead to SQL injection if the variable is user-controlled and is not properly sanitized. In order to prevent SQL injection, it is recommended to use parameterized queries or prepared statements."},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.express-sequelize-injection"},{"fingerprints":{"matchBasedId/v1":"668bcd76af120244c2bdd7b48430c372629da47e53be7998ccf6667e58fe2c323328101aee6763673b014f569e2c2ba05273b5b3574efe4d72096227427f9736_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-injection-express.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":76,"endLine":34,"snippet":{"text":"    m.sequelize.query(`SELECT * FROM Foo WHERE ((criteria LIKE '%${criteria}%))`)"},"startColumn":68,"startLine":34}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"f52391d87553631320063029ab81920483c06ca8063896fda4a04696097cec6731f72d2afdbd9f839e6acf3237c4a39bdc18c50cf6893475d0152345026571d3_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-injection-express.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":90,"endLine":36,"snippet":{"text":"    sequelize.query(`SELECT * FROM Foo WHERE ((criteria LIKE '%${obj.replacements[0]}%))`)"},"startColumn":21,"startLine":36}}}],"message":{"text":"Detected a sequelize statement that is tainted by user-input. This could lead to SQL injection if the variable is user-controlled and is not properly sanitized. In order to prevent SQL injection, it is recommended to use parameterized queries or prepared statements."},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.express-sequelize-injection"},{"fingerprints":{"matchBasedId/v1":"ad0ddc6e2b453d1f86370dfd69b47580feca4ebc0e2dd1ab74945bdb20ec3c23c16192c8ba629258111a1b86d34acdbf14107fa3445d73e4d5d8f5fd89fc1b0a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-injection-express.ts","uriBaseId":"%SRCROOT%"},"region":{"endColumn":86,"endLine":36,"snippet":{"text":"    sequelize.query(`SELECT * FROM Foo WHERE ((criteria LIKE '%${obj.replacements[0]}%))`)"},"startColumn":64,"startLine":36}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.tainted-sql-string"},{"fingerprints":{"matchBasedId/v1":"721a2fc2a69642e1b0a974323670fdeadc6f51c463eaddf5e1a90884ac79812824bce48996984aefad054ade32d58852b5372ad226e6438be19e6a861ed46d65_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-raw-query.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":5,"snippet":{"text":"db.sequelize.query(\n  `INSERT INTO user (username, password) VALUES('${username}','${password}')`\n)"},"startColumn":1,"startLine":3}}}],"message":{"text":"Avoiding SQL string concatenation: untrusted input concatenated with raw SQL query can result in SQL Injection. Data replacement or data binding should be used. See https://sequelize.org/master/manual/raw-queries.html"},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-raw-query"},{"fingerprints":{"matchBasedId/v1":"a881ad35ddc3fa377e374d4b27a30bc8c61e8028dbfa5be13959078cae7477d5feec1c18a09da710beb986d578a06d476435a3d2677ed32509f7919a84626e6f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-raw-query.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":11,"snippet":{"text":"var query = `INSERT INTO user (username, password) VALUES('${username}','${password}')`\nconsole.log(\"check password\");\ndb.sequelize.query(query)"},"startColumn":1,"startLine":9}}}],"message":{"text":"Avoiding SQL string concatenation: untrusted input concatenated with raw SQL query can result in SQL Injection. Data replacement or data binding should be used. See https://sequelize.org/master/manual/raw-queries.html"},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-raw-query"},{"fingerprints":{"matchBasedId/v1":"d4cab878579a66643e1b8aa0516e4b14b9cadb0fc3f581257ad570e3ed9f54ef6a0db19524a16e87eeff53a8266edbc67b798e447bb2388afb30aa5fcf3d60a3_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-raw-query.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":18,"snippet":{"text":"db.sequelize.query(\n  \"INSERT INTO user (username, password) VALUES('\" + username + \"','\" + password + \"')\"\n)"},"startColumn":1,"startLine":16}}}],"message":{"text":"Avoiding SQL string concatenation: untrusted input concatenated with raw SQL query can result in SQL Injection. Data replacement or data binding should be used. See https://sequelize.org/master/manual/raw-queries.html"},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-raw-query"},{"fingerprints":{"matchBasedId/v1":"1c1a342d6e41a6f8eb9a417b6623bf3a268aeb2a4ef90ac2fb5582ef0685a586f81016a670d86bc15b7eefc1a79c348a4dbc8cb2a9f610929e4713e23d023df6_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-raw-query.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":24,"snippet":{"text":"var query = \"INSERT INTO user (username, password) VALUES('\" + username + \"','\" + password + \"')\"\nconsole.log(\"check password\");\ndb.sequelize.query(query)"},"startColumn":1,"startLine":22}}}],"message":{"text":"Avoiding SQL string concatenation: untrusted input concatenated with raw SQL query can result in SQL Injection. Data replacement or data binding should be used. See https://sequelize.org/master/manual/raw-queries.html"},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-raw-query"},{"fingerprints":{"matchBasedId/v1":"94305761732809757e60bcbf864357c2dbb63b12b3c957a5ec690dccf8de99c55251c9e3e147457a2374f8159e6793e0bfeb822e19dc98bd2f1bc8ec4f3652ee_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-tls-disabled-cert-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":34,"snippet":{"text":"module.exports = {\n\n  // ruleid: sequelize-tls-disabled-cert-validation\n  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"mariadb\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        rejectUnauthorized: false\n      }\n    }\n  }\n};\n\n// Example for mysql\nmodule.exports = {\n\n  // ruleid: sequelize-tls-disabled-cert-validation\n  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"mysql\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        rejectUnauthorized: false\n      }\n    }\n  }\n};"},"startColumn":1,"startLine":3}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"9b205d1efc62fa6e131bf597c9f40563d332fd79a9990a7fab4b43c3c2883775d39cf75dc04b1ed225a2d9e3841cc7b69f2a4794047c864dea459a739044d1e3_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-tls-disabled-cert-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":16,"snippet":{"text":"  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"mariadb\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        rejectUnauthorized: false\n      }\n    }\n  }"},"startColumn":8,"startLine":6}}}],"message":{"text":"Set \"rejectUnauthorized\" to false is a convenient way to resolve certificate error. But this method is unsafe because it disables the server certificate verification, making the Node app open to MITM attack. \"rejectUnauthorized\" option must be alway set to True (default value). With self -signed certificate or custom CA, use \"ca\" option to define Root Certificate. This rule checks TLS configuration only for Postgresql, MariaDB and MySQL. SQLite is not really concerned by TLS configuration. This rule could be extended for MSSQL, but the dialectOptions is specific for Tedious."},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-tls-disabled-cert-validation"},{"fingerprints":{"matchBasedId/v1":"8f835ea521970c307d4c640bd67bfd0583b74a546d0506aa3169b57ed099d6c860f6c64d138d9df5bcf958815800c389aa06dd00166662a2616757806e0ab88c_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-tls-disabled-cert-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":3,"endLine":52,"snippet":{"text":"module.exports = {\n\n  // ruleid: sequelize-tls-disabled-cert-validation\n  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"mysql\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        rejectUnauthorized: false\n      }\n    }\n  }\n};\n\n\n// Example for postgresql\nmodule.exports = {\n\n  // ruleid: sequelize-tls-disabled-cert-validation\n  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"postgres\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        rejectUnauthorized: false\n      }\n    }\n  }\n};"},"startColumn":1,"startLine":20}}}],"message":{"text":"`module.exports` is assigned twice; the first assignment is useless"},"properties":{},"ruleId":"opengrep-rules.lang.correctness.useless-assignment"},{"fingerprints":{"matchBasedId/v1":"097adc6cc3bfe30e652df4697477f67d54373a456230848d98cbdb5c95608ad4df2b58e607d29d0ce127bab6eeda9848e4ea8af63d6bedd5493484bd3f3f17e0_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/sequelize/security/audit/sequelize-tls-disabled-cert-validation.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":4,"endLine":33,"snippet":{"text":"  dev: {\n    username: \"0xdbe\",\n    database: \"app_db\",\n    dialect: \"mysql\",\n    host: \"127.0.0.1\",\n    dialectOptions: {\n      ssl: {\n        rejectUnauthorized: false\n      }\n    }\n  }"},"startColumn":8,"startLine":23}}}],"message":{"text":"Set \"rejectUnauthorized\" to false is a convenient way to resolve certificate error. But this method is unsafe because it disables the server certificate verification, making the Node app open to MITM attack. \"rejectUnauthorized\" option must be alway set to True (default value). With self -signed certificate or custom CA, use \"ca\" option to define Root Certificate. This rule checks TLS configuration only for Postgresql, MariaDB and MySQL. SQLite is not really concerned by TLS configuration. This rule could be extended for MSSQL, but the dialectOptions is specific for Tedious."},"properties":{},"ruleId":"opengrep-rules.sequelize.security.audit.sequelize-tls-disabled-cert-validation"},{"fingerprints":{"matchB