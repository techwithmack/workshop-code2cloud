0d26d1f1f121c2dce9392c8dc13d5a7277c907d7884c5e27de3899c134391aa685b4cbaa302a8eb60632f401059b7d4_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-vm2-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":21,"endLine":57,"snippet":{"text":"  nodeVM.run(script)"},"startColumn":3,"startLine":57}}}],"message":{"text":"Make sure that unverified user data can not reach `vm2`."},"properties":{},"ruleId":"opengrep-rules.express.security.express-vm2-injection"},{"fingerprints":{"matchBasedId/v1":"4221990fe5893514c144a70177a512edac945cd7aa58497db1b921521c3e2dd8e6df45f2f67b202d617d6630b5a868d7a4b74f21a01e10375a6c6221c59531bd_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-vm2-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":124,"snippet":{"text":"app.get('/test4', async function test1(req, res) {\n  code = `\n    console.log(\"Hello world\")\n  `;\n\n  const sandbox = {\n    setTimeout,\n    watch: req.query.input\n  };\n\n  // ruleid:express-vm2-injection\n  return new VM({timeout: 40 * 1000, sandbox}).run(code);\n})"},"startColumn":19,"startLine":112}}}],"message":{"text":"Make sure that unverified user data can not reach `vm2`."},"properties":{},"ruleId":"opengrep-rules.vm2.security.audit.vm2-context-injection"},{"fingerprints":{"matchBasedId/v1":"3d3c028cfe0c239cbabc4ecc8feb5ca8a6041c61f3b2fb1c2b864495a47e9aa05948951cc6ec52ea2c0b003e3531b94ccc4cf965f4e9762477704066926dfda0_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-vm2-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":57,"endLine":123,"snippet":{"text":"  return new VM({timeout: 40 * 1000, sandbox}).run(code);"},"startColumn":10,"startLine":123}}}],"message":{"text":"Make sure that unverified user data can not reach `vm2`."},"properties":{},"ruleId":"opengrep-rules.express.security.express-vm2-injection"},{"fingerprints":{"matchBasedId/v1":"4221990fe5893514c144a70177a512edac945cd7aa58497db1b921521c3e2dd8e6df45f2f67b202d617d6630b5a868d7a4b74f21a01e10375a6c6221c59531bd_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-vm2-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":2,"endLine":135,"snippet":{"text":"app.post('/test5', function test2(req, res) {\n  const sandbox = {\n    setTimeout,\n    input: req.body\n  };\n\n  // ruleid:express-vm2-injection\n  const nodeVM = new NodeVM({timeout: 40 * 1000, sandbox});\n  return nodeVM\n})"},"startColumn":20,"startLine":126}}}],"message":{"text":"Make sure that unverified user data can not reach `vm2`."},"properties":{},"ruleId":"opengrep-rules.vm2.security.audit.vm2-context-injection"},{"fingerprints":{"matchBasedId/v1":"28d489722d2b0fa9f4c9328a2351966469d9a48ff9befe00dcc974080271934ce3573fe88f79d7c0bf46523f60030cf845ff31c1fcb0919f9f3a61753afc835a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-vm2-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":59,"endLine":133,"snippet":{"text":"  const nodeVM = new NodeVM({timeout: 40 * 1000, sandbox});"},"startColumn":18,"startLine":133}}}],"message":{"text":"Make sure that unverified user data can not reach `vm2`."},"properties":{},"ruleId":"opengrep-rules.express.security.express-vm2-injection"},{"fingerprints":{"matchBasedId/v1":"a0240c111a4ed58c7a0722e0de62c23b680a897c8b2e978f479892a14c2a5b89b019a29063a4c786873dd2fbdb99502735d658c2021b9d51831d5ca54b0777a7_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":2,"snippet":{"text":"const app = express()"},"startColumn":7,"startLine":2}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"72a6301f4679923634665ec880d44d96e025e0fb3b13dbe76c784fa16518c69999dd1ff75c8c628b9dd85aa57c2613687a877853dd8b181cc9b285be2203db5a_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":63,"endLine":9,"snippet":{"text":"  const pdf = wkhtmltopdf(req.query.q, { output: 'vuln.pdf' })"},"startColumn":15,"startLine":9}}}],"message":{"text":"If unverified user data can reach the `wkhtmltopdf` it can result in Server-Side Request Forgery vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.wkhtmltopdf.security.audit.wkhtmltopdf-injection"},{"fingerprints":{"matchBasedId/v1":"d7d0629a6265554ed4fe09a0bae71e8a6c342eec9cb14e0313253960c90d6738022371f13fee00d3870ef5041436eaf16ec18bede4e1702e4661e6cb13b8c65f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":38,"endLine":9,"snippet":{"text":"  const pdf = wkhtmltopdf(req.query.q, { output: 'vuln.pdf' })"},"startColumn":27,"startLine":9}}}],"message":{"text":"If unverified user data can reach the `wkhtmltopdf` methods it can result in Server-Side Request Forgery vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.express.security.express-wkhtmltopdf-injection"},{"fingerprints":{"matchBasedId/v1":"e260f63fef5c13bf9898b5e3032e1340d1d5cd2dfbceff3b8cdbea765ca2864ed56a14fa54085d568da5193377c0e792d3708d31b594b7889890dfff40f431ce_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":15,"endLine":10,"snippet":{"text":"  res.send(pdf)"},"startColumn":12,"startLine":10}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"ed005e1677243a2bd2ddbf54c9cc98666b2574feb7d750603d36d0cbc43036ac23b91f37b540dc3204121041b2dd83c16c64645159866b268890c2352d3b3cf5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":71,"endLine":21,"snippet":{"text":"  const img = wkhtmltoimage.generate(req.body, { output: 'vuln.pdf' })"},"startColumn":15,"startLine":21}}}],"message":{"text":"If unverified user data can reach the `wkhtmltoimage` it can result in Server-Side Request Forgery vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.wkhtmltoimage.security.audit.wkhtmltoimage-injection"},{"fingerprints":{"matchBasedId/v1":"1e694b4052986f219d239e1d671b2a65558c798fcea8a4f81289e07b13b85de82bdb01fad027028763bc2c0b35064c56273488381d2c4302de76ea3c39e00acf_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":46,"endLine":21,"snippet":{"text":"  const img = wkhtmltoimage.generate(req.body, { output: 'vuln.pdf' })"},"startColumn":38,"startLine":21}}}],"message":{"text":"If unverified user data can reach the `phantom` methods it can result in Server-Side Request Forgery vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.express.security.express-wkhtmltoimage-injection"},{"fingerprints":{"matchBasedId/v1":"7d07a2dce04966f0ac6eee5062e2c5c18d0850a5f0bbab9a748eca50c6e955cd43779b7ef2e7120fed37dcf2ff7eeadf59f65689718e4650394c13ffa1e9dca5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-wkhtml-injection.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":15,"endLine":22,"snippet":{"text":"  res.send(img)"},"startColumn":12,"startLine":22}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"aa410ea683e9d5c1d7fe66d8de9b6c7792dcca914c565c916de5ebb3f5acab37377ea56ca28ea227aded174c8929578d7e0d3d75c2078de1505cb8fd268cad84_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":39,"endLine":2,"snippet":{"text":"    const express = require('express')"},"startColumn":21,"startLine":2}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"b9674289636b9d9f958d1c806e82bec0fd51e586e34f0d6f9da13278eab96e8a22c17a5ed270213d4cac0ebdaceee2737c59ea068dcc83e128a502bd89b5026d_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":7,"endLine":12,"snippet":{"text":"    const xml2json = require('xml2json')\n    const app = express()\n    const port = 3000\n\n    app.get('/', (req, res) => {\n        const xml = req.query.xml\n        // ruleid: express-xml2json-xxe\n        const content = xml2json.toJson(xml, {coerce: true, object: true});\n        res.send(content)\n    })"},"startColumn":5,"startLine":3}}}],"message":{"text":"If unverified user data can reach the XML Parser it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.xml2json.security.audit.xml2json-xxe"},{"fingerprints":{"matchBasedId/v1":"aa410ea683e9d5c1d7fe66d8de9b6c7792dcca914c565c916de5ebb3f5acab37377ea56ca28ea227aded174c8929578d7e0d3d75c2078de1505cb8fd268cad84_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":41,"endLine":3,"snippet":{"text":"    const xml2json = require('xml2json')"},"startColumn":22,"startLine":3}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"c99359ec860e3d56d72d423a15d0b3790be8fb56a0856b272be65971cb134a585e37b4ee4e03ddeb47081355448f385d98ca2076265de712720d15420f8cae4f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":4,"snippet":{"text":"    const app = express()"},"startColumn":11,"startLine":4}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"b99e83e36169a79cb47e2efe57fddbbb7e6c7892bba855f705f51b8130d88ee183c5563b866d015e80e1aa1dc259fd3d9759b2e94924beb639c39165f8c2f366_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":10,"snippet":{"text":"        const content = xml2json.toJson(xml, {coerce: true, object: true});"},"startColumn":41,"startLine":10}}}],"message":{"text":"Make sure that unverified user data can not reach the XML Parser, as it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.express.security.express-xml2json-xxe"},{"fingerprints":{"matchBasedId/v1":"3785e5d497c1b4d0a80774a78bc9df2fd5d20900dcb55cb40d8067c30cc289ab0a82c0607a1a8ca262b41abb979938f27a9d6213a93acfbe56dc411925f4257f_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":25,"endLine":11,"snippet":{"text":"        res.send(content)"},"startColumn":18,"startLine":11}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"0a15161f557d2e3546e0fe378bbc2d24234a219e40de6249de0d9a0d8a0427ae06f0089a1c46f76aa86bbeb42d397b58201dbdb0f1ab0a83afe2c18be0b26e2b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":39,"endLine":18,"snippet":{"text":"    const express = require('express')"},"startColumn":21,"startLine":18}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"b9674289636b9d9f958d1c806e82bec0fd51e586e34f0d6f9da13278eab96e8a22c17a5ed270213d4cac0ebdaceee2737c59ea068dcc83e128a502bd89b5026d_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":7,"endLine":27,"snippet":{"text":"    const xml2json = require('xml2json')\n    const app = express()\n    const port = 3000\n\n    app.get('/', (req, res) => {\n        // ruleid: express-xml2json-xxe\n        const content = xml2json.toJson(req.body, {coerce: true, object: true});\n        res.send(content)\n    })"},"startColumn":5,"startLine":19}}}],"message":{"text":"If unverified user data can reach the XML Parser it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.xml2json.security.audit.xml2json-xxe"},{"fingerprints":{"matchBasedId/v1":"0a15161f557d2e3546e0fe378bbc2d24234a219e40de6249de0d9a0d8a0427ae06f0089a1c46f76aa86bbeb42d397b58201dbdb0f1ab0a83afe2c18be0b26e2b_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":41,"endLine":19,"snippet":{"text":"    const xml2json = require('xml2json')"},"startColumn":22,"startLine":19}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"c99359ec860e3d56d72d423a15d0b3790be8fb56a0856b272be65971cb134a585e37b4ee4e03ddeb47081355448f385d98ca2076265de712720d15420f8cae4f_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":20,"snippet":{"text":"    const app = express()"},"startColumn":11,"startLine":20}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"8a85ec284f8ca7cd8718a61826e92ab45c2c3d848fcd75fe9e093ceb5bfa775bfabc0fd2152a713439b1a614b269dea4997f140d00fdf8d11ca7976a57150c06_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":49,"endLine":25,"snippet":{"text":"        const content = xml2json.toJson(req.body, {coerce: true, object: true});"},"startColumn":41,"startLine":25}}}],"message":{"text":"Make sure that unverified user data can not reach the XML Parser, as it can result in XML External or Internal Entity (XXE) Processing vulnerabilities"},"properties":{},"ruleId":"opengrep-rules.express.security.express-xml2json-xxe"},{"fingerprints":{"matchBasedId/v1":"3785e5d497c1b4d0a80774a78bc9df2fd5d20900dcb55cb40d8067c30cc289ab0a82c0607a1a8ca262b41abb979938f27a9d6213a93acfbe56dc411925f4257f_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":25,"endLine":26,"snippet":{"text":"        res.send(content)"},"startColumn":18,"startLine":26}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"3d6930f05e8e15f67ad64465d15d1ba7a99864987d534400d3aefbb0cdbed9f505a9cd49505df7007bfa526a471233d765cbf50dd0dc8b9628e9f0b3aaf7aea5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":39,"endLine":33,"snippet":{"text":"    const express = require('express')"},"startColumn":21,"startLine":33}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"3d6930f05e8e15f67ad64465d15d1ba7a99864987d534400d3aefbb0cdbed9f505a9cd49505df7007bfa526a471233d765cbf50dd0dc8b9628e9f0b3aaf7aea5_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":41,"endLine":34,"snippet":{"text":"    const xml2json = require('xml2json')"},"startColumn":22,"startLine":34}}}],"message":{"text":"Lazy loading can complicate code bundling if care is not taken, also `require`s are run synchronously by Node.js. If they are called from within a function, it may block other requests from being handled at a more critical time. The best practice is to `require` modules at the beginning of each file, before and outside of any functions."},"properties":{},"ruleId":"opengrep-rules.lang.best-practice.lazy-load-module"},{"fingerprints":{"matchBasedId/v1":"c99359ec860e3d56d72d423a15d0b3790be8fb56a0856b272be65971cb134a585e37b4ee4e03ddeb47081355448f385d98ca2076265de712720d15420f8cae4f_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/express-xml2json-xxe.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":26,"endLine":35,"snippet":{"text":"    const app = express()"},"startColumn":11,"startLine":35}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"b222625a4822f1bb2d23d5cb648da989cd05871a9c5ce684b652e3a73bce67cf922a08207259811299dcbba5a07d5bef4e5ca29b745c960a8b9df96cde639b49_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/raw-html-format.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":2,"snippet":{"text":"const app = express()"},"startColumn":7,"startLine":2}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprin