ng '<%- ... %>' If external data can reach these locations, your application is exposed to a cross-site scripting (XSS) vulnerability. Use '<%= ... %>' to escape this data. If you need escaping, ensure no external data can reach this location."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.ejs.template-explicit-unescape"},{"fingerprints":{"matchBasedId/v1":"cdef0cbb9b41d4158bef25c255889cadcf967fc07e6917dcba20b2ba35c8889b8e0847a73b50f1cef7ce75d0927c28c9347278a38309c129084f0e7683f6b7c3_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/ejs/explicit-unescape.ejs","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":40,"snippet":{"text":"                    <b><%- nome %></b>"},"startColumn":24,"startLine":40}}}],"message":{"text":"Detected an explicit unescape in an EJS template, using '<%- ... %>' If external data can reach these locations, your application is exposed to a cross-site scripting (XSS) vulnerability. Use '<%= ... %>' to escape this data. If you need escaping, ensure no external data can reach this location."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.ejs.template-explicit-unescape"},{"fingerprints":{"matchBasedId/v1":"97d9ef14005bd5c45b2270baa440e1fff8416a9351cd76613289564a218a09bd086139889eb79908f48d6fa8fe897a92d61cbbc3ba1f5c7394759c3ee5e7a518_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/ejs/var-in-href.ejs","uriBaseId":"%SRCROOT%"},"region":{"endColumn":47,"endLine":32,"snippet":{"text":"    <a href=\"<%= link %>\" class=\"text-center\">Click me</a>"},"startColumn":5,"startLine":32}}}],"message":{"text":"Detected a template variable used in an anchor tag with the 'href' attribute. This allows a malicious actor to input the 'javascript:' URI and is subject to cross- site scripting (XSS) attacks. If using a relative URL, start with a literal forward slash and concatenate the URL, like this: href='/<%= link %>'. You may also consider setting the Content Security Policy (CSP) header."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.ejs.var-in-href"},{"fingerprints":{"matchBasedId/v1":"62befe5f2d6e0036a5a7baba4b3cd8c45fcf2d14ce186a0c434774b9cb82457516dd50ef2408f2d859602eb0b32a7a54f1cae3b159928d2afaf3bbee9765d8ea_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/ejs/var-in-script-src.ejs","uriBaseId":"%SRCROOT%"},"region":{"endColumn":44,"endLine":44,"snippet":{"text":"<script src=\"./<%=reactDemoIndexBundleJs %>\" crossOrigin=\"anonymous\" integrity=\"<%=sri.reactDemoIndexBundleJs %>\"></script>"},"startColumn":16,"startLine":44}}}],"message":{"text":"Detected a template variable used as the 'src' in a script tag. Although template variables are HTML escaped, HTML escaping does not always prevent malicious URLs from being injected and could results in a cross-site scripting (XSS) vulnerability. Prefer not to dynamically generate the 'src' attribute and use static URLs instead. If you must do this, carefully check URLs against an allowlist and be sure to URL-encode the result."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.ejs.var-in-script-src"},{"fingerprints":{"matchBasedId/v1":"361f42371023a0656613356faff29419af14db2127723d1dfb462312575c077da175a256af93a92fe4b1573977416f59636a1e15e094213eb9b13f51e27e2d6b_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/ejs/var-in-script-tag.ejs","uriBaseId":"%SRCROOT%"},"region":{"endColumn":33,"endLine":24,"snippet":{"text":"    var message = <%= message %>;"},"startColumn":19,"startLine":24}}}],"message":{"text":"Detected a template variable used in a script tag. Although template variables are HTML escaped, HTML escaping does not always prevent cross-site scripting (XSS) attacks when used directly in JavaScript. If you need this data on the rendered page, consider placing it in the HTML portion (outside of a script tag). Alternatively, use a JavaScript-specific encoder, such as the one available in OWASP ESAPI."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.ejs.var-in-script-tag"},{"fingerprints":{"matchBasedId/v1":"361f42371023a0656613356faff29419af14db2127723d1dfb462312575c077da175a256af93a92fe4b1573977416f59636a1e15e094213eb9b13f51e27e2d6b_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/ejs/var-in-script-tag.ejs","uriBaseId":"%SRCROOT%"},"region":{"endColumn":33,"endLine":29,"snippet":{"text":"    var message = <%= message %>;"},"startColumn":19,"startLine":29}}}],"message":{"text":"Detected a template variable used in a script tag. Although template variables are HTML escaped, HTML escaping does not always prevent cross-site scripting (XSS) attacks when used directly in JavaScript. If you need this data on the rendered page, consider placing it in the HTML portion (outside of a script tag). Alternatively, use a JavaScript-specific encoder, such as the one available in OWASP ESAPI."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.ejs.var-in-script-tag"},{"fingerprints":{"matchBasedId/v1":"361f42371023a0656613356faff29419af14db2127723d1dfb462312575c077da175a256af93a92fe4b1573977416f59636a1e15e094213eb9b13f51e27e2d6b_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/audit/xss/ejs/var-in-script-tag.ejs","uriBaseId":"%SRCROOT%"},"region":{"endColumn":35,"endLine":33,"snippet":{"text":"    var message2 = <%= message2 %>;"},"startColumn":20,"startLine":33}}}],"message":{"text":"Detected a template variable used in a script tag. Although template variables are HTML escaped, HTML escaping does not always prevent cross-site scripting (XSS) attacks when used directly in JavaScript. If you need this data on the rendered page, consider placing it in the HTML portion (outside