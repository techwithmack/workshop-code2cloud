ert in Buffer API, which allows the offset the be beyond the end of the buffer. This could result in writing or reading beyond the end of the buffer."},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-buffer-noassert"},{"fingerprints":{"matchBasedId/v1":"f85ba62c07ec401b16e4c1d29ccae686acfb59463998d61ac85a75cc47f3339cc2d5f270c6a7365edd90fec7812d8de667feb5ff77b169a0547565c294c32c94_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/detect-buffer-noassert.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":24,"endLine":11,"snippet":{"text":"a.writeFloatLE(0, true)"},"startColumn":1,"startLine":11}}}],"message":{"text":"Detected usage of noassert in Buffer API, which allows the offset the be beyond the end of the buffer. This could result in writing or reading beyond the end of the buffer."},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-buffer-noassert"},{"fingerprints":{"matchBasedId/v1":"d798b0cafff66e9991409f63064432fa7fe100df09a782e31134a71c884bcd9f68e969ba4e4b3bf0019b2024d37880b3bc527432edd120a95e52c17041382d73_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/lang/security/detect-child-process.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":36,"endLine":6,"snippet":{"text":"  exec(`cat *.js ${args[0]}| wc -l`, (error, stdout, stderr) => {"},"startColumn":8,"startLine":6}}}],"message":{"text":"Detected calls to child_process from a function argument `args`. This could lead to a command injection if the input is user controllable. Try to avoid calls to child_process, and if it is needed ensure user input is correctly sanitized or sandboxed. "},"properties":{},"ruleId":"opengrep-rules.lang.security.detect-child-process"},{"fingerprints":{"matchBasedId/v1":"97f7fc6a87f2a1aeb52ab1959cf256d6a46e989f61993cce98e04a26c36831ed517bf628c7abfdeaf18161f49ca9c156c85f5b6383d2ce2963215263abc540f5_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/la