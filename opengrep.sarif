tion to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"f4c5be0489ab30887cb9b4fcdf934b7a44c8af85eba62dbd952381959b8891ef232773ba7485c66c779dc109244236d85d68a4b093749f20ffb9168125db92b0_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":22,"endLine":2,"snippet":{"text":"const app = express()"},"startColumn":7,"startLine":2}}}],"message":{"text":"A CSRF middleware was not detected in your express application. Ensure you are either using one such as `csurf` or `csrf` (see rule references) and/or you are properly doing CSRF validation in your routes with a token or cookies."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.express-check-csurf-middleware-usage"},{"fingerprints":{"matchBasedId/v1":"50286eabda2febc6ef89670a455362ddbdc74da1994853dbebd34314c71ec681a1b5ef44a3b1e6965299d3eb42677a9bae994ff185433c7ea3f021e454aba379_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/tainted-sql-string.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":78,"endLine":10,"snippet":{"text":"  const query = \"SELECT * FROM `users`\" + \" WHERE id = '\" + req.query.message + \"'\""},"startColumn":61,"startLine":10}}}],"message":{"text":"Detected user input used to manually construct a SQL string. This is usually bad practice because manual construction could accidentally result in a SQL injection. An attacker could use a SQL injection to steal or modify contents of the database. Instead, use a parameterized query which is available by default in most database engines. Alternatively, consider using an object-relational mapper (ORM) such as Sequelize which will protect your queries."},"properties":{},"ruleId":"o