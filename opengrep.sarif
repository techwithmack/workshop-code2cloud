:{"endColumn":54,"endLine":12,"snippet":{"text":"    res.send(`<h1>message: ${req.query.message}</h1>`);"},"startColumn":14,"startLine":12}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"aafee397e456d0ee31175b6357bd824fdb1aefa0655be936b986c9e00406b28caf35997648ef141a87c09233b460ee643991d13168f18235bc77ef94bc7d77bf_1"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/raw-html-format.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":54,"endLine":12,"snippet":{"text":"    res.send(`<h1>message: ${req.query.message}</h1>`);"},"startColumn":14,"startLine":12}}}],"message":{"text":"User data flows into the host portion of this manually-constructed HTML. This can introduce a Cross-Site-Scripting (XSS) vulnerability if this comes from user-provided input. Consider using a sanitization library such as DOMPurify to sanitize the HTML within."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.raw-html-format"},{"fingerprints":{"matchBasedId/v1":"6e102c67a67b0f7d0a4fa83425c91d732b2f3623a6ae23837710ad6c4bb4eeb4a8d234da3c81e8241db51de926a6b0a2ef7885d3d46815d0c73a9481600a2b64_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/raw-html-format.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":54,"endLine":12,"snippet":{"text":"    res.send(`<h1>message: ${req.query.message}</h1>`);"},"startColumn":14,"startLine":12}}}],"message":{"text":"This template literal looks like HTML and has interpolated variables. These variables are not HTML-encoded by default. If the variables contain HTML tags, these may be interpreted by the browser, resulting in cross-site scripting (XSS)."},"properties":{},"ruleId":"opengrep-rules.lang.security.html-in-template-string"},{"fingerprints":{"matchBasedId/v1":"aafee397e456d0ee31175b6357bd824fdb1aefa0655be936b986c9e00406b28caf35997648ef141a87c09233b460ee643991d13168f18235bc77ef94bc7d77bf_2"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/raw-html-format.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":56,"endLine":17,"snippet":{"text":"    var html = \"<h1>\" + \"message: \" + req.query.message + \"</h1>\""},"startColumn":16,"startLine":17}}}],"message":{"text":"User data flows into the host portion of this manually-constructed HTML. This can introduce a Cross-Site-Scripting (XSS) vulnerability if this comes from user-provided input. Consider using a sanitization library such as DOMPurify to sanitize the HTML within."},"properties":{},"ruleId":"opengrep-rules.express.security.injection.raw-html-format"},{"fingerprints":{"matchBasedId/v1":"a7e173198a354a7ba9c231c2e94c237816d4ec698b531368666b65d7303c090c3dbafcd7cec15382baa2487595f12c742b95e3c2416606ac4fdbaeb034181391_0"},"locations":[{"physicalLocation":{"artifactLocation":{"uri":"opengrep-rules/express/security/injection/raw-html-format.js","uriBaseId":"%SRCROOT%"},"region":{"endColumn":18,"endLine":18,"snippet":{"text":"    res.send(html);"},"startColumn":14,"startLine":18}}}],"message":{"text":"Detected directly writing to a Response object from user-defined input. This bypasses any HTML escaping and may expose your application to a Cross-Site-scripting (XSS) vulnerability. Instead, use 'resp.render()' to render safely escaped HTML."},"properties":{},"ruleId":"opengrep-rules.express.security.audit.xss.direct-response-write"},{"fingerprints":{"matchBasedId/v1":"aafee397e456d0ee31175b6357bd824fdb1aefa0655be936b986c9e00406b28caf35997648ef141a87c09233b460ee643991d13168f18235bc77ef94bc7d77bf_3"},"locations":[{"physicalLocation":{"artifactLocation